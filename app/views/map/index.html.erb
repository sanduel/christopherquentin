<% content_for(:title, "Map — Christopher Quentin") %>
<% content_for(:head) do %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<% end %>

<section class="max-w-[1180px] mx-auto px-6 lg:px-10 pt-20 pb-12">
  <div class="flex items-center gap-3">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">The Map · trees, hives, memories</span>
  </div>
  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(40px, 5.5vw, 72px); line-height: 1.0;">
    Where he left his mark.
  </h1>
  <p class="text-[16px] text-muted mt-5 max-w-[640px]">
    Trees, events, memories, and bee hives that carry Christopher&rsquo;s memory forward.
  </p>
</section>

<div class="max-w-[1180px] mx-auto px-6 lg:px-10 mb-20" data-controller="unified-map" data-unified-map-pins-value="<%= @pins.to_json %>">
  <div class="flex flex-wrap gap-3 mb-4">
    <% @category_meta.each do |meta| %>
      <label class="inline-flex items-center gap-2 text-[14px] text-muted bg-white-bg px-3 py-1.5 rounded-full border border-ink/10 cursor-pointer hover:border-ink/20 transition-colors">
        <input type="checkbox"
               checked
               data-action="change->unified-map#toggleCategory"
               data-unified-map-target="filter"
               data-category="<%= meta[:key] %>">
        <span class="inline-block w-2.5 h-2.5 rounded-full" style="background-color: <%= meta[:default_color] %>"></span>
        <%= meta[:label] %>
      </label>
    <% end %>
  </div>

  <div id="unified-map" class="w-full h-[600px] rounded-[5px] border border-ink/8 shadow-[0_1px_2px_rgba(17,17,17,0.04)]" data-unified-map-target="map"></div>

  <% if @pins.empty? %>
    <p class="font-serif italic text-[18px] text-muted text-center py-6">No mapped items yet. Add a tree, event, memory, or bee hive to populate the map.</p>
  <% end %>
</div>

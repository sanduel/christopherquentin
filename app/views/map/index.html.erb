<% content_for(:title, "Map — Christopher Quentin") %>
<% content_for(:head) do %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<% end %>

<section class="px-6 lg:px-14 pt-12 pb-8">
  <%= musical_eyebrow("Op. X · The Map", with_rule: true) %>
  <h1 class="font-serif text-5xl md:text-6xl lg:text-[80px] font-normal leading-tight tracking-tight text-ink mt-3">
    Where he <em class="font-serif italic text-moss">lived</em>.
  </h1>
  <p class="text-[17px] text-ink/65 mt-3 max-w-[640px]">
    Trees, events, memories, and bee hives that carry Christopher&rsquo;s memory forward.
  </p>
</section>

<div class="px-6 lg:px-14 pb-20" data-controller="unified-map" data-unified-map-pins-value="<%= @pins.to_json %>">
  <div class="flex flex-wrap gap-3 mb-4">
    <% @category_meta.each do |meta| %>
      <label class="inline-flex items-center gap-2 text-sm text-ink/70 bg-white px-3 py-1.5 rounded-full border border-ink/10 cursor-pointer hover:border-ink/20 transition-colors">
        <input type="checkbox"
               checked
               data-action="change->unified-map#toggleCategory"
               data-unified-map-target="filter"
               data-category="<%= meta[:key] %>">
        <span class="inline-block w-2.5 h-2.5 rounded-full" style="background-color: <%= meta[:default_color] %>"></span>
        <%= meta[:label] %>
      </label>
    <% end %>
  </div>

  <div id="unified-map" class="w-full h-[600px] rounded-md border border-ink/8 shadow-card" data-unified-map-target="map"></div>

  <% if @pins.empty? %>
    <p class="font-serif italic text-xl text-ink/50 text-center py-6">No mapped items yet. Add a tree, event, memory, or bee hive to populate the map.</p>
  <% end %>
</div>

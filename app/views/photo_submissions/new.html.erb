<% content_for :title, "Submit Photos — Christopher Quentin" %>

<section class="px-6 lg:px-14 py-12 lg:py-16 max-w-[760px] mx-auto">
  <%= musical_eyebrow("Op. IV.ii · Submit photos", with_rule: true) %>
  <h1 class="font-serif text-4xl md:text-5xl lg:text-[64px] font-normal leading-tight tracking-tight text-ink mt-3">
    Submit <em class="font-serif italic text-moss">photos</em>.
  </h1>
  <p class="text-[17px] text-ink/65 mt-3 max-w-[560px]">
    Share your photos of Christopher. They will be reviewed before being added to the gallery.
  </p>

  <%= form_with model: @photo_submission, class: "space-y-5 mt-10", multipart: true do |f| %>
    <% if @photo_submission.errors.any? %>
      <div class="bg-linen border-l-2 border-rose text-rose p-3 text-sm">
        <ul>
          <% @photo_submission.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Your name", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_field :name, required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :email, "Email", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.email_field :email, required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :photos, "Photos", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.file_field :photos, multiple: true, accept: "image/*", class: "block" %>
      <p class="text-xs text-ink/40 mt-1">You can select up to 25 photos at once.</p>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Submit photos →",
            class: "bg-moss text-cream rounded-full px-6 py-3 text-sm font-medium hover:bg-ink transition-colors cursor-pointer" %>
    </div>
  <% end %>
</section>

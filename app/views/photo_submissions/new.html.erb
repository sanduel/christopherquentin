<% content_for(:title, "Submit Photos — Christopher Quentin") %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-4xl font-title text-stone-800 mb-2">Submit Photos</h1>
  <p class="text-stone-500 mb-8">Share your photos of Christopher. They will be reviewed before being added to the gallery.</p>

  <%= form_with model: @photo_submission, class: "space-y-6" do |f| %>
    <% if @photo_submission.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4">
        <ul class="text-red-700 text-sm">
          <% @photo_submission.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Your Name", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :name, required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :email, "Your Email", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.email_field :email, required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :photos, "Photos", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.file_field :photos, multiple: true, accept: "image/*", class: "text-sm text-stone-600" %>
      <p class="text-xs text-stone-400 mt-1">You can select up to 25 photos at once.</p>
    </div>

    <%= f.submit "Submit Photos", class: "w-full px-4 py-3 bg-blue-800 text-white rounded-lg hover:bg-blue-700 transition cursor-pointer font-medium" %>
  <% end %>
</div>

<h1 class="text-3xl font-title text-stone-800 mb-6">Edit Tribute — <%= @tribute.name %></h1>

<%= form_with model: [ :admin, @tribute ], local: true, multipart: true, class: "space-y-6 max-w-3xl" do |f| %>
  <% if @tribute.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4">
      <ul class="text-red-700 text-sm">
        <% @tribute.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :name, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
    </div>
    <div>
      <%= f.label :relationship, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :relationship, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
    </div>
  </div>

  <div>
    <%= f.label :category, class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.select :category, Tribute.categories.keys.map { |c| [c.titleize, c] }, {}, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
  </div>

  <div>
    <%= f.label :content, class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_area :content, rows: 10, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
  </div>

  <div>
    <%= f.label :photo, "Replace photo (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.file_field :photo, accept: "image/*", class: "block" %>
    <% if @tribute.photo.attached? %>
      <p class="text-xs text-stone-500 mt-1">Currently attached: <%= @tribute.photo.filename %></p>
    <% end %>
  </div>

  <div class="flex gap-3">
    <%= f.submit "Save", class: "px-4 py-2 bg-stone-800 text-white rounded hover:bg-stone-700 transition cursor-pointer" %>
    <%= link_to "Cancel", admin_tributes_path, class: "px-4 py-2 border border-stone-300 text-stone-700 rounded hover:bg-stone-100 transition" %>
  </div>
<% end %>

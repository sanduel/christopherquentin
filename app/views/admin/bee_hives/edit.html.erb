<h1 class="text-3xl font-title text-stone-800 mb-6">Edit Pin — <%= @bee_hive.name %></h1>

<%= form_with model: [ :admin, @bee_hive ], local: true, class: "space-y-6 max-w-2xl" do |f| %>
  <%= render "admin/shared/pin_overrides", f: f, record: @bee_hive %>

  <div class="flex gap-3">
    <%= f.submit "Save", class: "px-4 py-2 bg-stone-800 text-white rounded hover:bg-stone-700 transition cursor-pointer" %>
    <%= link_to "Cancel", admin_bee_hives_path, class: "px-4 py-2 border border-stone-300 text-stone-700 rounded hover:bg-stone-100 transition" %>
  </div>
<% end %>

<h1 class="text-3xl font-title text-stone-800 mb-4">Bee Hives</h1>

<%= render "admin/shared/filter_tabs" %>

<div class="space-y-4">
  <% @bee_hives.each do |hive| %>
    <div class="bg-white p-6 rounded-lg shadow-sm border border-stone-200">
      <div class="flex justify-between items-start mb-3">
        <div>
          <span class="font-medium text-stone-800"><%= hive.name %></span>
          <span class="text-stone-400 text-sm ml-2"><%= hive.address %></span>
          <span class="ml-2"><%= render "admin/shared/status_badge", status: hive.status %></span>
          <% if hive.latitude.nil? %>
            <span class="px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-800 ml-1">Needs geocoding</span>
          <% end %>
        </div>
        <%= link_to "Edit pin", edit_admin_bee_hive_path(hive), class: "text-xs text-blue-700 hover:text-blue-600 underline" %>
      </div>
      <% if hive.story.present? %>
        <p class="text-stone-600 text-sm mb-4"><%= truncate(hive.story, length: 200) %></p>
      <% end %>
      <%= render "admin/shared/moderation_actions", record: hive %>
    </div>
  <% end %>

  <% if @bee_hives.empty? %>
    <p class="text-stone-400 italic">No hives yet.</p>
  <% end %>
</div>

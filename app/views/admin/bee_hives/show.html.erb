<h1 class="text-3xl font-title text-stone-800 mb-4"><%= @bee_hive.name %></h1>

<div class="bg-white p-6 rounded-lg shadow-sm border border-stone-200 space-y-2">
  <p><span class="text-stone-500">Address:</span> <%= @bee_hive.address %></p>
  <% if @bee_hive.email.present? %>
    <p><span class="text-stone-500">Email:</span> <%= @bee_hive.email %></p>
  <% end %>
  <p><span class="text-stone-500">Status:</span> <%= render "admin/shared/status_badge", status: @bee_hive.status %></p>
  <% if @bee_hive.story.present? %>
    <p class="whitespace-pre-line"><%= @bee_hive.story %></p>
  <% end %>
</div>

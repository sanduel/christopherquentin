<div class="flex justify-between items-start mb-6">
  <h1 class="text-3xl font-title text-stone-800"><%= @event.title %></h1>
  <%= link_to "Edit", edit_admin_event_path(@event), class: "px-4 py-2 bg-blue-700 text-white rounded hover:bg-blue-600 transition" %>
</div>

<div class="bg-white p-6 rounded-lg shadow-sm border border-stone-200 space-y-3">
  <div>
    <span class="text-sm font-medium text-stone-500 uppercase tracking-wide">Type:</span>
    <span class="ml-2"><%= event_type_label(@event) %></span>
  </div>
  <div>
    <span class="text-sm font-medium text-stone-500 uppercase tracking-wide">Status:</span>
    <span class="ml-2"><%= @event.published? ? "Published" : "Draft" %></span>
  </div>
  <div>
    <span class="text-sm font-medium text-stone-500 uppercase tracking-wide block mb-1">Starts:</span>
    <ul class="text-stone-700 text-sm">
      <% event_zone_lines(@event.starts_at).each do |line| %>
        <li><%= line %></li>
      <% end %>
    </ul>
  </div>
  <% if @event.ends_at.present? %>
    <div>
      <span class="text-sm font-medium text-stone-500 uppercase tracking-wide block mb-1">Ends:</span>
      <ul class="text-stone-700 text-sm">
        <% event_zone_lines(@event.ends_at).each do |line| %>
          <li><%= line %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <% if @event.location.present? %>
    <div>
      <span class="text-sm font-medium text-stone-500 uppercase tracking-wide">Location:</span>
      <span class="ml-2"><%= @event.location %></span>
    </div>
  <% end %>
  <% if @event.url.present? %>
    <div>
      <span class="text-sm font-medium text-stone-500 uppercase tracking-wide">URL:</span>
      <%= link_to @event.url, @event.url, target: "_blank", rel: "noopener", class: "ml-2 text-blue-700 hover:text-blue-600 underline break-all" %>
    </div>
  <% end %>
  <% if @event.description.present? %>
    <div>
      <span class="text-sm font-medium text-stone-500 uppercase tracking-wide block mb-1">Description:</span>
      <p class="text-stone-700 whitespace-pre-line"><%= @event.description %></p>
    </div>
  <% end %>
</div>

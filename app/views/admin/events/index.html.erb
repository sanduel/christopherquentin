<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-title text-stone-800">Events</h1>
  <%= link_to "+ New Event", new_admin_event_path, class: "px-4 py-2 bg-stone-800 text-white rounded hover:bg-stone-700 transition" %>
</div>

<div class="space-y-4">
  <% @events.each do |event| %>
    <div class="bg-white p-6 rounded-lg shadow-sm border border-stone-200">
      <div class="flex justify-between items-start mb-3">
        <div>
          <span class="font-medium text-stone-800"><%= event.title %></span>
          <span class="ml-2 inline-block px-2 py-0.5 rounded text-xs font-medium <%= event_type_badge_classes(event) %>"><%= event_type_label(event) %></span>
          <span class="ml-2 inline-block px-2 py-0.5 rounded text-xs font-medium <%= event.published? ? "bg-green-100 text-green-800" : "bg-yellow-100 text-yellow-800" %>"><%= event.published? ? "Published" : "Draft" %></span>
        </div>
        <span class="text-xs text-stone-400"><%= event.starts_at.in_time_zone("America/New_York").strftime("%b %d, %Y · %-l:%M %p %Z") %></span>
      </div>
      <% if event.location.present? %>
        <p class="text-stone-600 text-sm mb-3"><%= event.location %></p>
      <% end %>
      <div class="flex gap-2">
        <%= link_to "Edit", edit_admin_event_path(event), class: "px-3 py-1 bg-blue-700 text-white text-sm rounded hover:bg-blue-600 transition" %>
        <%= button_to "Delete", admin_event_path(event), method: :delete, data: { turbo_confirm: "Delete this event?" }, class: "px-3 py-1 bg-stone-600 text-white text-sm rounded hover:bg-stone-500 transition" %>
      </div>
    </div>
  <% end %>

  <% if @events.empty? %>
    <p class="text-stone-400 italic">No events yet.</p>
  <% end %>
</div>

<%= form_with model: [:admin, record], local: true, multipart: true, class: "space-y-6 max-w-3xl" do |f| %>
  <% if record.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4">
      <ul class="text-red-700 text-sm">
        <% record.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :title, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :title, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
    </div>
    <div>
      <%= f.label :submitter_name, "Submitter", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :submitter_name, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
    </div>
  </div>

  <div>
    <%= f.label :ingredients, class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_area :ingredients, rows: 6, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
  </div>

  <div>
    <%= f.label :instructions, class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_area :instructions, rows: 10, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
  </div>

  <div>
    <%= f.label :photo, record.new_record? ? "Photo (optional)" : "Replace photo (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.file_field :photo, accept: "image/*", class: "block" %>
    <% if record.photo.attached? %>
      <p class="text-xs text-stone-500 mt-1">Currently attached: <%= record.photo.filename %></p>
    <% end %>
  </div>

  <div class="border-t border-stone-200 pt-6">
    <%= f.label :user_id, "Assign to user (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.collection_select :user_id, User.order(:name), :id, :name,
          { include_blank: "— Anonymous (no account) —" },
          class: "w-full px-3 py-2 border border-stone-300 rounded" %>
    <p class="text-xs text-stone-500 mt-1">Leave blank to keep this recipe attributed to its submitter name only.</p>
  </div>

  <div>
    <%= f.label :status, class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.select :status, Recipe.statuses.keys.map { |k| [k.titleize, k] }, {}, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
  </div>

  <div class="flex gap-3">
    <%= f.submit (record.new_record? ? "Create" : "Save"),
          class: "px-4 py-2 bg-stone-800 text-white rounded hover:bg-stone-700 transition cursor-pointer" %>
    <%= link_to "Cancel", admin_recipes_path,
          class: "px-4 py-2 border border-stone-300 text-stone-700 rounded hover:bg-stone-100 transition" %>
  </div>
<% end %>

<h1 class="text-3xl font-title text-stone-800 mb-4">Recipes</h1>

<%= render "admin/shared/filter_tabs" %>

<div class="space-y-4">
  <% @recipes.each do |recipe| %>
    <div class="bg-white p-6 rounded-lg shadow-sm border border-stone-200">
      <div class="flex justify-between items-start mb-3">
        <div>
          <span class="font-medium text-stone-800"><%= recipe.title %></span>
          <span class="text-stone-400 text-sm ml-2">by <%= recipe.submitter_name %></span>
          <span class="ml-2"><%= render "admin/shared/status_badge", status: recipe.status %></span>
        </div>
        <span class="text-xs text-stone-400"><%= recipe.created_at.strftime("%b %d, %Y") %></span>
      </div>
      <div class="flex justify-between items-center">
        <%= render "admin/shared/moderation_actions", record: recipe %>
        <%= link_to "Edit", edit_admin_recipe_path(recipe), class: "text-xs text-blue-700 hover:text-blue-600 underline" %>
      </div>
    </div>
  <% end %>
</div>

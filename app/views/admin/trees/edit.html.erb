<h1 class="text-3xl font-title text-stone-800 mb-6">Edit Tree — <%= @tree.name %></h1>

<%= form_with model: [ :admin, @tree ], local: true, multipart: true, class: "space-y-6 max-w-3xl" do |f| %>
  <% if @tree.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4">
      <ul class="text-red-700 text-sm">
        <% @tree.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :name, "Submitter name", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :name, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
    </div>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.email_field :email, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-4">
    <div>
      <%= f.label :address, "Location (will re-geocode if changed)", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :address, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
    </div>
    <div>
      <%= f.label :tree_count, "Number of trees", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.number_field :tree_count, min: 1, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
    </div>
  </div>

  <div>
    <%= f.label :story, "Story (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_area :story, rows: 5, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
  </div>

  <div>
    <%= f.label :photo, "Replace photo", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.file_field :photo, accept: "image/*", class: "block" %>
    <% if @tree.photo.attached? %>
      <p class="text-xs text-stone-500 mt-1">Currently attached: <%= @tree.photo.filename %></p>
    <% end %>
  </div>

  <%= render "admin/shared/pin_overrides", f: f, record: @tree %>

  <div class="flex gap-3">
    <%= f.submit "Save", class: "px-4 py-2 bg-stone-800 text-white rounded hover:bg-stone-700 transition cursor-pointer" %>
    <%= link_to "Cancel", admin_trees_path, class: "px-4 py-2 border border-stone-300 text-stone-700 rounded hover:bg-stone-100 transition" %>
  </div>
<% end %>

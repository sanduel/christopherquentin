<div class="flex items-center justify-between mb-4">
  <h1 class="text-3xl font-title text-stone-800">Trees</h1>
  <%= link_to "+ New tree", new_admin_tree_path,
        class: "px-4 py-2 bg-stone-800 text-white rounded text-sm hover:bg-stone-700 transition" %>
</div>

<%= render "admin/shared/filter_tabs" %>

<div class="space-y-4">
  <% @trees.each do |tree| %>
    <div class="bg-white p-6 rounded-lg shadow-sm border border-stone-200">
      <div class="flex justify-between items-start mb-3">
        <div>
          <span class="font-medium text-stone-800"><%= tree.name %></span>
          <span class="text-stone-400 text-sm ml-2"><%= tree.address %></span>
          <span class="ml-2"><%= render "admin/shared/status_badge", status: tree.status %></span>
          <% if tree.latitude.nil? %>
            <span class="px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-800 ml-1">Needs geocoding</span>
          <% end %>
        </div>
        <span class="text-xs text-stone-400"><%= pluralize(tree.tree_count, "tree") %></span>
      </div>
      <% if tree.story.present? %>
        <p class="text-stone-600 text-sm mb-4"><%= truncate(tree.story, length: 200) %></p>
      <% end %>
      <div class="flex justify-between items-center">
        <%= render "admin/shared/moderation_actions", record: tree %>
        <%= link_to "Edit pin", edit_admin_tree_path(tree), class: "text-xs text-blue-700 hover:text-blue-600 underline" %>
      </div>
    </div>
  <% end %>
</div>

<h1 class="text-3xl font-title text-stone-800 mb-4">Photo Submissions</h1>

<%= render "admin/shared/filter_tabs" %>

<div class="space-y-4">
  <% @submissions.each do |submission| %>
    <div class="bg-white p-6 rounded-lg shadow-sm border border-stone-200">
      <div class="flex justify-between items-start mb-3">
        <div>
          <span class="font-medium text-stone-800"><%= submission.name %></span>
          <span class="text-stone-400 text-sm ml-2"><%= submission.email %></span>
          <span class="ml-2"><%= render "admin/shared/status_badge", status: submission.status %></span>
        </div>
        <span class="text-xs text-stone-400"><%= submission.photos.count %> photo(s)</span>
      </div>
      <% if submission.photos.attached? %>
        <div class="flex gap-2 flex-wrap mb-4">
          <% submission.photos.limit(4).each do |photo| %>
            <%= image_tag photo.variant(resize_to_limit: [100, 100]), class: "rounded" %>
          <% end %>
          <% if submission.photos.count > 4 %>
            <span class="text-stone-400 text-sm self-center">+<%= submission.photos.count - 4 %> more</span>
          <% end %>
        </div>
      <% end %>
      <%= render "admin/shared/moderation_actions", record: submission %>
    </div>
  <% end %>
</div>

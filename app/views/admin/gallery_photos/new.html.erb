<h1 class="text-3xl font-title text-stone-800 mb-8">Add Gallery Photo</h1>

<%= form_with model: [:admin, @photo], class: "max-w-lg space-y-6" do |f| %>
  <div>
    <%= f.label :photo, "Photo", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.file_field :photo, accept: "image/*", required: true, class: "text-sm text-stone-600" %>
  </div>

  <div>
    <%= f.label :caption, "Caption", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_field :caption, class: "w-full px-3 py-2 border border-stone-300 rounded-lg" %>
  </div>

  <div>
    <%= f.label :sort_order, "Sort Order", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.number_field :sort_order, value: 0, class: "w-32 px-3 py-2 border border-stone-300 rounded-lg" %>
  </div>

  <%= f.submit "Add Photo", class: "px-4 py-2 bg-blue-800 text-white rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
<% end %>

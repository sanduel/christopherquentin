<h1 class="text-3xl font-title text-stone-800 mb-8">Edit Gallery Photo</h1>

<%= form_with model: [:admin, @photo], class: "max-w-lg space-y-6" do |f| %>
  <% if @photo.photo.attached? %>
    <div>
      <%= image_tag @photo.photo.variant(resize_to_limit: [300, 300]), class: "rounded-lg" %>
    </div>
  <% end %>

  <div>
    <%= f.label :photo, "Replace Photo", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.file_field :photo, accept: "image/*", class: "text-sm text-stone-600" %>
  </div>

  <div>
    <%= f.label :caption, "Caption", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_field :caption, class: "w-full px-3 py-2 border border-stone-300 rounded-lg" %>
  </div>

  <div>
    <%= f.label :sort_order, "Sort Order", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.number_field :sort_order, class: "w-32 px-3 py-2 border border-stone-300 rounded-lg" %>
  </div>

  <div>
    <%= f.label :status, class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.select :status, GalleryPhoto.statuses.keys.map { |k| [ k.titleize, k ] }, {}, class: "w-full px-3 py-2 border border-stone-300 rounded-lg" %>
  </div>

  <label class="flex items-center gap-2">
    <%= f.check_box :featured, class: "h-4 w-4" %>
    <span class="text-sm font-medium text-stone-700">Featured on home page</span>
  </label>

  <label class="flex items-center gap-2">
    <%= f.check_box :bio_grid, class: "h-4 w-4" %>
    <span class="text-sm font-medium text-stone-700">Show in biography photo grid</span>
  </label>

  <% if @photo.submitted? %>
    <p class="text-sm text-stone-500">Submitted by <%= @photo.submitter_name.presence %> <%= "(#{@photo.submitter_email})" if @photo.submitter_email.present? %></p>
  <% end %>

  <%= f.submit "Update Photo", class: "px-4 py-2 bg-blue-800 text-white rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
<% end %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-title text-stone-800">Gallery</h1>
  <%= link_to "Add Photo", new_admin_gallery_photo_path, class: "px-4 py-2 bg-blue-800 text-white rounded hover:bg-blue-700 transition" %>
</div>

<% if @photos.any? %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <% @photos.each do |photo| %>
      <div class="bg-white p-3 rounded-lg shadow-sm border border-stone-200">
        <% if photo.photo.attached? %>
          <%= image_tag photo.photo.variant(resize_to_limit: [200, 200]), class: "rounded w-full aspect-square object-cover mb-2" %>
        <% end %>
        <p class="text-xs text-stone-500 truncate"><%= photo.caption %></p>
        <p class="text-xs text-stone-400">Order: <%= photo.sort_order %></p>
        <div class="flex gap-1 mt-2">
          <%= link_to "Edit", edit_admin_gallery_photo_path(photo), class: "text-xs text-blue-800 hover:text-blue-700" %>
          <%= button_to "Delete", admin_gallery_photo_path(photo), method: :delete, data: { turbo_confirm: "Remove this photo?" }, class: "text-xs text-red-600 hover:text-red-500" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-stone-400 italic text-center py-12">No gallery photos yet.</p>
<% end %>

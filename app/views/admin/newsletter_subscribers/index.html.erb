<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-title text-stone-800">Subscribers <span class="text-stone-400 text-xl">(<%= @subscribers.size %>)</span></h1>
  <% if @subscribers.any? %>
    <%= link_to "Export CSV", admin_newsletter_subscribers_path(format: :csv),
          class: "px-4 py-2 bg-stone-800 text-white rounded text-sm hover:bg-stone-700 transition" %>
  <% end %>
</div>

<div class="space-y-2">
  <% @subscribers.each do |subscriber| %>
    <div class="bg-white px-6 py-4 rounded-lg shadow-sm border border-stone-200 flex justify-between items-center gap-4">
      <div>
        <span class="font-medium text-stone-800"><%= subscriber.email %></span>
        <span class="ml-3 text-xs text-stone-400"><%= subscriber.created_at.strftime("%b %d, %Y") %></span>
      </div>
      <%= button_to "Delete", admin_newsletter_subscriber_path(subscriber), method: :delete,
            data: { turbo_confirm: "Remove #{subscriber.email}?" },
            class: "px-3 py-1 bg-stone-600 text-white text-sm rounded hover:bg-stone-500 transition" %>
    </div>
  <% end %>

  <% if @subscribers.empty? %>
    <p class="text-stone-400 italic">No subscribers yet.</p>
  <% end %>
</div>

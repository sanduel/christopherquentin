<% content_for :title, "Edit tribute — Christopher Quentin" %>

<section class="max-w-[760px] mx-auto px-6 lg:px-10 pt-20 pb-24">
  <%# Eyebrow %>
  <div class="flex items-center gap-3">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">Tributes · Edit (admin)</span>
  </div>

  <%# Title %>
  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(40px, 5.5vw, 64px); line-height: 1.0;">
    Edit tribute.
  </h1>

  <%= form_with model: @tribute, url: tribute_path(@tribute), method: :patch,
        class: "space-y-6 mt-12", multipart: true do |f| %>
    <% if @tribute.errors.any? %>
      <div class="bg-band border-l-2 border-[#b91c1c] text-[#b91c1c] px-4 py-3 text-sm">
        <ul class="list-none m-0 p-0 space-y-1">
          <% @tribute.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :name, "Name", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
        <%= f.text_field :name, required: true,
              class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      </div>
      <div>
        <%= f.label :relationship, "Relationship to Christopher", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
        <%= f.text_field :relationship,
              class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :category, "Category", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
        <%= f.select :category, Tribute.categories.keys.map { |c| [c.titleize, c] }, {},
              class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      </div>
      <div>
        <%= f.label :status, "Status", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
        <%= f.select :status, Tribute.statuses.keys.map { |s| [s.titleize, s] }, {},
              class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      </div>
    </div>

    <div>
      <%= f.label :content, "Tribute", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.text_area :content, rows: 8,
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors leading-relaxed" %>
      <p class="text-[13px] text-muted mt-2">A written tribute, a YouTube video, or both.</p>
    </div>

    <div>
      <%= f.label :video_url, "YouTube video", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.url_field :video_url,
            placeholder: "https://www.youtube.com/watch?v=…",
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
    </div>

    <div>
      <%= f.label :photo, @tribute.photo.attached? ? "Replace photo" : "Photo", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.file_field :photo, accept: "image/*",
            class: "block text-sm text-ink file:mr-4 file:py-2 file:px-4 file:rounded-md file:border file:border-ink/22 file:bg-white-bg file:text-ink file:font-medium hover:file:border-ink" %>
      <% if @tribute.photo.attached? %>
        <p class="text-[13px] text-muted mt-2">Currently attached: <%= @tribute.photo.filename %></p>
      <% end %>
    </div>

    <div>
      <%= f.label :user_id, "Attributed account (optional)", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.collection_select :user_id, User.order(:name), :id, :name,
            { include_blank: "— Anonymous (no account) —" },
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <%= f.submit "Save changes",
            class: "bg-ink text-white-bg no-underline text-[15px] font-semibold py-[15px] px-7 rounded-md hover:bg-ink-deep transition-colors cursor-pointer border-0" %>
      <%= link_to "Cancel", tribute_path(@tribute),
            class: "self-center text-accent text-[15px] font-semibold no-underline hover:opacity-70 transition-opacity" %>
    </div>
  <% end %>
</section>

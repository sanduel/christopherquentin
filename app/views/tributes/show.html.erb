<% content_for(:title, "Tribute from #{@tribute.name} — Christopher Quentin") %>

<section class="max-w-[760px] mx-auto px-6 lg:px-10 pt-20 pb-24">
  <%= link_to "← All tributes", tributes_path,
        class: "font-mono text-[11px] tracking-[0.18em] uppercase text-mono hover:text-accent no-underline transition-colors" %>

  <% if @tribute.photo.attached? %>
    <%= image_tag @tribute.photo, class: "w-full aspect-[16/9] object-cover rounded-[3px] mt-10" %>
  <% end %>

  <article class="mt-10">
    <span class="font-serif text-[100px] leading-[0.5] text-accent" aria-hidden="true">&ldquo;</span>
    <blockquote class="mt-6">
      <p class="font-serif italic text-[24px] md:text-[28px] leading-[1.45] text-quote m-0"><%= @tribute.content %></p>
      <footer class="mt-10 pt-6 border-t border-ink/10">
        <div class="font-bold text-[17px] text-ink">&mdash; <%= @tribute.name %></div>
        <% if @tribute.relationship.present? %>
          <div class="font-mono text-[12px] tracking-[0.18em] uppercase text-accent mt-1.5"><%= @tribute.relationship %></div>
        <% end %>
      </footer>
    </blockquote>
  </article>
</section>

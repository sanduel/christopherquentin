<% content_for(:title, "Tribute from #{@tribute.name} — Christopher Quentin") %>

<section class="px-6 lg:px-14 py-12 lg:py-16 max-w-[860px] mx-auto">
  <span class="font-serif text-[80px] text-rose leading-none block -mb-4">&ldquo;</span>

  <blockquote class="mt-2">
    <p class="font-serif italic text-[24px] md:text-[28px] leading-relaxed text-ink">
      <%= @tribute.content %>
    </p>

    <footer class="mt-8 pt-6 border-t border-ink/8">
      <p class="font-serif text-xl text-ink font-medium">&mdash; <%= @tribute.name %></p>
      <% if @tribute.relationship.present? %>
        <%= musical_eyebrow(@tribute.relationship) %>
      <% end %>
    </footer>
  </blockquote>

  <div class="mt-12">
    <%= link_to "← All tributes", tributes_path, class: "text-moss text-sm font-medium hover:underline no-underline" %>
  </div>
</section>

<% content_for :title, "Share a Tribute — Christopher Quentin" %>

<section class="px-6 lg:px-14 py-12 lg:py-16 max-w-[760px] mx-auto">
  <%= musical_eyebrow("Op. V · Share a tribute", with_rule: true) %>
  <h1 class="font-serif text-4xl md:text-5xl lg:text-[64px] font-normal leading-tight tracking-tight text-ink mt-3">
    Share a <em class="font-serif italic text-moss">tribute</em>.
  </h1>
  <p class="text-[17px] text-ink/65 mt-3 max-w-[560px]">
    Write a few words in Christopher's memory. Your tribute will be reviewed and added to the collection.
  </p>

  <%= form_with model: @tribute, class: "space-y-5 mt-10", multipart: true do |f| %>
    <% if @tribute.errors.any? %>
      <div class="bg-linen border-l-2 border-rose text-rose p-3 text-sm">
        <ul>
          <% @tribute.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Your name", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_field :name, required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :relationship, "Your relationship to Christopher", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_field :relationship,
            placeholder: "e.g. Friend, Colleague, Family",
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :category, "Category", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.select :category, Tribute.categories.keys.map { |c| [c.titleize, c] }, {},
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :content, "Your tribute", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_area :content, required: true, rows: 8,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :photo, "Photo (optional)", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.file_field :photo, accept: "image/*", class: "block" %>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Submit tribute →",
            class: "bg-moss text-cream rounded-full px-6 py-3 text-sm font-medium hover:bg-ink transition-colors cursor-pointer" %>
      <%= link_to "Cancel", tributes_path,
            class: "text-moss text-sm font-medium hover:underline no-underline self-center" %>
    </div>
  <% end %>
</section>

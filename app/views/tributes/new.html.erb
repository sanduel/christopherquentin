<% content_for(:title, "Share a Tribute — Christopher Quentin") %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-4xl font-title text-stone-800 mb-8">Share a Tribute</h1>

  <%= form_with model: @tribute, class: "space-y-6" do |f| %>
    <% if @tribute.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4">
        <ul class="text-red-700 text-sm">
          <% @tribute.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Your Name", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :name, required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :relationship, "Your Relationship to Christopher", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :relationship, placeholder: "e.g. Friend, Colleague, Family", class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :content, "Your Tribute", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_area :content, required: true, rows: 8, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :photo, "Photo (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.file_field :photo, accept: "image/*", class: "text-sm text-stone-600" %>
    </div>

    <%= f.submit "Submit Tribute", class: "w-full px-4 py-3 bg-blue-800 text-white rounded-lg hover:bg-blue-700 transition cursor-pointer font-medium" %>
  <% end %>
</div>

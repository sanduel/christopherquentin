<% content_for(:title, "#{@event.title} — Christopher Quentin") %>

<section class="max-w-[860px] mx-auto px-6 lg:px-10 pt-20 pb-24">
  <%= link_to "← All events", events_path,
        class: "font-mono text-[11px] tracking-[0.18em] uppercase text-mono hover:text-accent no-underline transition-colors" %>

  <div class="flex items-center gap-3 mt-8">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent"><%= @event.event_type.titleize %></span>
  </div>

  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(40px, 5vw, 64px); line-height: 1.0;">
    <%= @event.title %>
  </h1>

  <% if @event.location.present? %>
    <p class="font-serif italic text-[20px] text-quote mt-5"><%= @event.location %></p>
  <% end %>

  <% if @event.cover_image.attached? %>
    <%= image_tag @event.cover_image, class: "w-full aspect-[16/9] object-cover rounded-[3px] border border-ink/8 my-10" %>
  <% end %>

  <%# Time card — visitor picks the display timezone %>
  <div class="bg-white-bg rounded-[5px] border border-ink/8 shadow-card p-6 mt-10 max-w-[460px]" data-controller="timezone">
    <div class="flex items-start justify-between gap-4 mb-4">
      <div class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">When</div>
      <%= event_timezone_select(classes: "text-[13px] text-ink bg-white-bg border border-ink/15 rounded-full px-3 py-1.5 cursor-pointer hover:border-ink/30 transition-colors") %>
    </div>
    <p class="font-serif text-[19px] text-ink mb-1">
      <%= event_date_tag(@event.starts_at) %>
    </p>
    <div class="text-[14px] text-ink/70">
      <%= event_time_tag(@event.starts_at) %>
    </div>

    <% if @event.ends_at.present? %>
      <div class="mt-6 pt-6 border-t border-ink/10">
        <div class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent mb-4">Until</div>
        <p class="font-serif text-[19px] text-ink mb-1">
          <%= event_date_tag(@event.ends_at) %>
        </p>
        <div class="text-[14px] text-ink/70">
          <%= event_time_tag(@event.ends_at) %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @event.description.present? %>
    <div class="mt-10">
      <div class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent mb-4">About</div>
      <p class="font-serif text-[19px] leading-relaxed text-ink whitespace-pre-line"><%= @event.description %></p>
    </div>
  <% end %>

  <% if (event_url = safe_event_url(@event.url)) %>
    <div class="mt-10">
      <%= link_to @event.concert? ? "Tickets / Details →" : "Join #{@event.event_type.titleize} →",
            event_url,
            target: "_blank", rel: "noopener",
            class: "inline-block bg-ink text-white-bg rounded-md px-6 py-3 font-semibold text-[15px] hover:bg-accent transition-colors no-underline cursor-pointer" %>
    </div>
  <% end %>
</section>

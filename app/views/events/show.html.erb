<% content_for(:title, "#{@event.title} — Christopher Quentin") %>

<div class="max-w-3xl mx-auto">
  <%= link_to "← All events", events_path, class: "text-sm text-blue-800 hover:text-blue-700" %>

  <% if @event.cover_image.attached? %>
    <div class="mt-6 mb-6 overflow-hidden rounded-lg">
      <%= image_tag @event.cover_image, class: "w-full max-h-96 object-cover" %>
    </div>
  <% end %>

  <div class="flex items-center gap-3 mt-6 mb-3">
    <span class="inline-block px-2 py-0.5 rounded text-xs font-medium <%= event_type_badge_classes(@event) %>"><%= event_type_label(@event) %></span>
  </div>

  <h1 class="text-4xl font-title text-stone-800 mb-6"><%= @event.title %></h1>

  <div class="bg-white p-6 rounded-lg shadow-sm border border-stone-200 mb-6">
    <h2 class="text-sm font-medium text-stone-500 uppercase tracking-wide mb-3">When</h2>
    <ul class="text-stone-700 space-y-1">
      <% event_zone_lines(@event.starts_at).each do |line| %>
        <li><%= line %></li>
      <% end %>
    </ul>
    <% if @event.ends_at.present? %>
      <h2 class="text-sm font-medium text-stone-500 uppercase tracking-wide mb-3 mt-4">Until</h2>
      <ul class="text-stone-700 space-y-1">
        <% event_zone_lines(@event.ends_at).each do |line| %>
          <li><%= line %></li>
        <% end %>
      </ul>
    <% end %>

    <% if @event.location.present? %>
      <h2 class="text-sm font-medium text-stone-500 uppercase tracking-wide mb-2 mt-4">Where</h2>
      <p class="text-stone-700"><%= @event.location %></p>
    <% end %>
  </div>

  <% if @event.description.present? %>
    <div class="prose max-w-none text-stone-700 mb-8 whitespace-pre-line leading-relaxed">
      <%= @event.description %>
    </div>
  <% end %>

  <% if @event.url.present? %>
    <%= link_to (@event.concert? ? "Tickets / Details" : "Join Webinar"), @event.url,
          target: "_blank", rel: "noopener",
          class: "inline-block px-6 py-3 bg-stone-800 text-blue-100 rounded hover:bg-stone-700 transition font-medium" %>
  <% end %>
</div>

<%= link_to event_path(event), class: "block bg-white p-6 rounded-lg shadow-sm border border-stone-200 hover:border-blue-300 hover:shadow-md transition" do %>
  <div class="md:flex gap-6">
    <% if event.cover_image.attached? %>
      <div class="md:w-48 md:flex-shrink-0 mb-4 md:mb-0">
        <%= image_tag event.cover_image, class: "w-full h-32 md:h-32 object-cover rounded" %>
      </div>
    <% end %>
    <div class="flex-1">
      <div class="flex items-start justify-between gap-3 mb-2">
        <h3 class="text-xl font-title text-blue-900"><%= event.title %></h3>
        <span class="inline-block px-2 py-0.5 rounded text-xs font-medium <%= event_type_badge_classes(event) %>"><%= event_type_label(event) %></span>
      </div>
      <ul class="text-sm text-stone-600 mb-2 space-y-0.5">
        <% event_zone_lines(event.starts_at).each do |line| %>
          <li><%= line %></li>
        <% end %>
      </ul>
      <% if event.location.present? %>
        <p class="text-sm text-stone-500"><%= event.location %></p>
      <% end %>
    </div>
  </div>
<% end %>

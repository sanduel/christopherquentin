<% content_for(:title, "Events — Christopher Quentin") %>

<section class="px-6 lg:px-14 pt-12 pb-8">
  <%= musical_eyebrow("Op. X · Gatherings", with_rule: true) %>
  <h1 class="font-serif text-5xl md:text-6xl lg:text-[80px] font-normal leading-tight tracking-tight text-ink mt-3">
    Where we <em class="font-serif italic text-moss">gathered</em>.
  </h1>
  <p class="text-[17px] text-ink/65 mt-3 max-w-[640px]">
    Concerts and webinars in Christopher&rsquo;s memory.
  </p>
</section>

<section class="px-6 lg:px-14 pb-20">
  <% if @upcoming_events.any? %>
    <div class="mb-14">
      <h2 class="font-serif text-2xl text-ink mb-6 pb-3 border-b border-ink/10">Upcoming</h2>
      <div class="space-y-4">
        <% @upcoming_events.each do |event| %>
          <%= render "event_card", event: event %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="mb-14">
      <h2 class="font-serif text-2xl text-ink mb-6 pb-3 border-b border-ink/10">Upcoming</h2>
      <p class="font-serif italic text-xl text-ink/50">No upcoming events scheduled. Check back soon.</p>
    </div>
  <% end %>

  <% if @past_events.any? %>
    <div>
      <h2 class="font-serif text-2xl text-ink mb-6 pb-3 border-b border-ink/10">Past</h2>
      <div class="space-y-4">
        <% @past_events.each do |event| %>
          <%= render "event_card", event: event %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>

<% content_for(:title, "Events — Christopher Quentin") %>

<div class="max-w-4xl mx-auto">
  <h1 class="text-4xl font-title text-stone-800 mb-2">Events</h1>
  <p class="text-stone-600 mb-10">Concerts and webinars in Christopher&rsquo;s memory.</p>

  <section class="mb-12">
    <h2 class="text-2xl font-title text-stone-700 mb-4">Upcoming</h2>
    <% if @upcoming_events.any? %>
      <div class="space-y-4">
        <% @upcoming_events.each do |event| %>
          <%= render "event_card", event: event %>
        <% end %>
      </div>
    <% else %>
      <p class="text-stone-400 italic">No upcoming events scheduled. Check back soon.</p>
    <% end %>
  </section>

  <% if @past_events.any? %>
    <section>
      <h2 class="text-2xl font-title text-stone-700 mb-4">Past</h2>
      <div class="space-y-4">
        <% @past_events.each do |event| %>
          <%= render "event_card", event: event %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

<% content_for(:title, "#{@memory.title.presence || 'Memory'} — Christopher Quentin") %>

<section class="max-w-[860px] mx-auto px-6 lg:px-10 pt-20 pb-24"
         data-controller="reply-toggle">

  <%= link_to "← All memories", memories_path,
        class: "font-mono text-[11px] tracking-[0.18em] uppercase text-mono hover:text-accent no-underline transition-colors" %>

  <%# Eyebrow: kind + date + location %>
  <% eyebrow_parts = ["Memory", l(@memory.date, format: :memory)] %>
  <% eyebrow_parts << @memory.location if @memory.location.present? %>
  <div class="flex items-center gap-3 mt-8">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent"><%= eyebrow_parts.join(" · ") %></span>
  </div>

  <% if @memory.title.present? %>
    <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
        style="font-size: clamp(40px, 5vw, 64px); line-height: 1.0;">
      <%= @memory.title %>
    </h1>
  <% end %>

  <% if @memory.kind_audio? %>
    <%# Audio player block %>
    <div class="mt-10 bg-white-bg rounded-[5px] border border-ink/8 overflow-hidden">
      <% if @memory.audio_clip.attached? %>
        <div class="bg-ink text-white-bg p-4 flex items-center gap-3 rounded-[5px]"
             data-controller="audio-player"
             data-audio-player-url-value="<%= url_for(@memory.audio_clip) %>">
          <button type="button"
                  data-action="audio-player#toggle"
                  data-audio-player-target="playButton"
                  class="w-10 h-10 rounded-full bg-white-bg text-ink font-bold text-lg flex items-center justify-center hover:bg-band cursor-pointer">
            ▶
          </button>
          <div class="flex-1 min-w-0">
            <% if @memory.audio_label.present? %>
              <div class="font-serif italic text-base truncate"><%= @memory.audio_label %></div>
            <% end %>
            <div data-audio-player-target="waveform" class="mt-1 h-4"></div>
          </div>
          <% if @memory.audio_length.present? %>
            <div data-audio-player-target="duration" class="font-mono text-[11px] tracking-[0.14em] uppercase text-white-bg/70 whitespace-nowrap">
              <%= @memory.audio_length %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-ink/5 text-muted p-6 text-center font-mono text-[11px] tracking-[0.14em] uppercase">[ audio not attached ]</div>
      <% end %>
      <% if @memory.content.present? %>
        <div class="p-7">
          <p class="font-serif text-[19px] leading-relaxed text-ink whitespace-pre-wrap"><%= @memory.content %></p>
        </div>
      <% end %>
    </div>

  <% elsif @memory.kind_photo? %>
    <%# Photo grid %>
    <% if @memory.photos.attached? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-10">
        <% @memory.photos.each do |photo| %>
          <%= image_tag photo.variant(resize_to_limit: [800, 600]), class: "rounded-[3px] w-full object-cover border border-ink/8" %>
        <% end %>
      </div>
    <% end %>
    <% if @memory.content.present? %>
      <p class="font-serif text-[19px] leading-relaxed text-ink mt-8 whitespace-pre-wrap"><%= @memory.content %></p>
    <% end %>

  <% else %>
    <%# Text memory %>
    <% if @memory.content.present? %>
      <p class="font-serif italic text-[22px] leading-[1.5] text-quote mt-6 whitespace-pre-wrap"><%= @memory.content %></p>
    <% end %>
  <% end %>

  <%# Footer: submitter info + reply button %>
  <footer class="mt-10 pt-6 border-t border-ink/10 flex justify-between items-end">
    <div>
      <div class="font-bold text-[15px] text-ink"><%= @memory.display_name %></div>
      <% if @memory.display_relationship %>
        <div class="font-mono text-[11px] tracking-[0.14em] uppercase text-accent mt-1"><%= @memory.display_relationship %></div>
      <% end %>
    </div>
    <button type="button"
            data-action="reply-toggle#toggle"
            class="border border-ink/22 text-ink hover:border-accent hover:text-accent rounded-md px-3 py-1.5 font-mono text-[11px] tracking-[0.14em] uppercase cursor-pointer transition-colors">
      ↩ Reply
    </button>
  </footer>

  <%# Published replies %>
  <% if @memory.replies.published.any? %>
    <div class="mt-6 space-y-3">
      <% @memory.replies.published.each do |reply| %>
        <%= render "memories/reply", reply: reply %>
      <% end %>
    </div>
  <% end %>

  <%# Reply composer %>
  <%= render "memories/reply_composer", memory: @memory %>

</section>

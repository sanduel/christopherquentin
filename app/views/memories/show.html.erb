<% content_for(:title, "#{@memory.title || 'Memory'} — Christopher Quentin") %>

<div class="max-w-3xl mx-auto">
  <%= link_to "← Timeline", memories_path, class: "text-blue-800 hover:text-blue-700 mb-6 inline-block" %>

  <div class="bg-white p-8 rounded-lg shadow-sm border border-stone-200">
    <p class="text-blue-800 font-medium mb-2"><%= @memory.date.strftime("%B %d, %Y") %></p>
    <% if @memory.title.present? %>
      <h1 class="text-3xl font-title text-stone-800 mb-4"><%= @memory.title %></h1>
    <% end %>
    <% if @memory.content.present? %>
      <div class="text-stone-600 leading-relaxed text-lg mb-6 whitespace-pre-wrap"><%= @memory.content %></div>
    <% end %>
    <% if @memory.photos.attached? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <% @memory.photos.each do |photo| %>
          <%= image_tag photo.variant(resize_to_limit: [600, 400]), class: "rounded-lg w-full" %>
        <% end %>
      </div>
    <% end %>
    <p class="text-stone-400 text-sm">Shared by <%= @memory.user&.name || "Anonymous" %></p>
  </div>
</div>

<%# Shared footer for memory cards: name, relationship, kind badge, reply button.
    Local: memory %>
<footer class="mt-5 pt-4 border-t border-ink/8 flex justify-between items-end">
  <div>
    <div class="font-bold text-[15px] text-ink"><%= memory.display_name %></div>
    <% if memory.display_relationship %>
      <div class="font-mono text-[11px] tracking-[0.16em] uppercase text-accent mt-0.5"><%= memory.display_relationship %></div>
    <% end %>
  </div>
  <div class="flex items-center gap-3">
    <span class="font-mono text-[11px] tracking-[0.14em] uppercase text-mono">
      <%= { "text" => "letter", "photo" => "photograph", "audio" => "recording" }[memory.kind] %>
    </span>
    <button type="button"
            data-action="reply-toggle#toggle"
            class="border border-ink/22 text-muted hover:border-accent hover:text-accent rounded-md px-3 py-1 text-[12px] cursor-pointer transition-colors">
      ↩ Reply
    </button>
  </div>
</footer>

<% content_for(:title, "Add a Memory — Christopher Quentin") %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-4xl font-title text-stone-800 mb-2">Add a Memory</h1>
  <p class="text-stone-500 mb-8">Share a specific story or moment from Christopher's life. It will appear on the timeline at the date you choose.</p>

  <%= form_with model: @memory, class: "space-y-6" do |f| %>
    <% if @memory.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4">
        <ul class="text-red-700 text-sm">
          <% @memory.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :date, "When did this happen?", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.date_field :date, required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :title, "Title (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :title, placeholder: "e.g. First rehearsal in Munich", class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :content, "The Memory", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_area :content, rows: 8, placeholder: "Tell us the story...", class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :location, "Where? (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :location, placeholder: "e.g. Munich, Germany", class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
      <p class="text-xs text-stone-400 mt-1">If filled in, this memory will appear as a pin on the unified map.</p>
    </div>

    <div>
      <%= f.label :photos, "Photos (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.file_field :photos, multiple: true, accept: "image/*", class: "text-sm text-stone-600" %>
      <p class="text-xs text-stone-400 mt-1">You can select multiple photos.</p>
    </div>

    <%= f.submit "Submit Memory", class: "w-full px-4 py-3 bg-blue-800 text-white rounded-lg hover:bg-blue-700 transition cursor-pointer font-medium" %>
  <% end %>
</div>

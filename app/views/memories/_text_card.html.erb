<%# Text memory card — quoted serif body, meta footer.
    Local: memory %>
<article data-memory-id="<%= memory.id %>" data-kind="text"
         data-controller="reply-toggle"
         class="bg-white-bg rounded-[5px] border border-ink/8 shadow-[0_1px_2px_rgba(17,17,17,0.05)] p-7 max-w-[480px] mx-auto mb-8 lg:mb-10 lg:<%= memory.id.odd? ? 'mr-auto lg:ml-0' : 'ml-auto lg:mr-0' %>">
  <div class="font-mono text-[11px] tracking-[0.16em] uppercase text-accent">
    <%= l(memory.date, format: :memory) %><% if memory.location.present? %> · <%= memory.location %><% end %>
  </div>
  <% if memory.video? %>
    <div class="aspect-video w-full rounded-[3px] overflow-hidden bg-ink mt-4">
      <iframe src="<%= memory.youtube_embed_url %>" loading="lazy"
              class="w-full h-full" frameborder="0" allowfullscreen
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              title="Memory video from <%= memory.display_name %>"></iframe>
    </div>
  <% end %>
  <% if memory.content.present? %>
    <blockquote class="font-serif text-[20px] leading-relaxed text-ink mt-4 mb-0">
      <%= simple_format("“#{memory.content}”") %>
    </blockquote>
  <% end %>
  <%= render "memories/card_footer", memory: memory %>
  <% memory.replies.published.each do |reply| %>
    <%= render "memories/reply", reply: reply %>
  <% end %>
  <%= render "memories/reply_composer", memory: memory %>
</article>

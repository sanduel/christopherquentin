<%#
  Memorial dark footer — four-column layout with newsletter, three link
  columns, and bottom copyright bar. Used by every page via application.html.erb.
%>
<footer class="bg-ink font-sans" style="padding: 80px 0 40px;">
  <div class="max-w-[1180px] mx-auto px-6 lg:px-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr_1fr] gap-10">

    <%# Col 1 — Newsletter %>
    <div>
      <div class="text-eyebrow mb-3.5" style="color:#C9C9C9">Stay in touch</div>
      <h3 class="font-serif text-[30px] font-normal leading-tight m-0" style="color:#E8E8E8">
        We send updates a few times a year.
      </h3>
      <%= form_with url: newsletter_subscribers_path,
            class: "flex gap-2 max-w-[460px] mt-5",
            local: true do |f| %>
        <%= f.email_field :email,
              placeholder: "your email",
              required: true,
              "aria-label": "Email address",
              class: "flex-1 bg-transparent border border-white/20 rounded-md px-4 py-3 text-sm placeholder:text-white/45 focus:border-white/55 outline-none",
              style: "color:#E8E8E8" %>
        <%= f.submit "Subscribe",
              class: "bg-white-bg text-ink rounded-md px-5 py-3 text-sm font-medium cursor-pointer hover:bg-white transition-colors" %>
      <% end %>
    </div>

    <%# Col 2 — Christopher %>
    <div>
      <div class="text-eyebrow mb-3.5" style="color:#C9C9C9">Christopher</div>
      <ul class="list-none p-0 m-0 space-y-1.5">
        <li class="text-sm">
          <%= link_to "Biography", chris_path,
                class: "no-underline hover:text-white transition-colors",
                style: "color:#C9C9C9" %>
        </li>
        <li class="text-sm">
          <%= link_to "Press", updates_path,
                class: "no-underline hover:text-white transition-colors",
                style: "color:#C9C9C9" %>
        </li>
        <li class="text-sm">
          <%= link_to "Tributes", tributes_path,
                class: "no-underline hover:text-white transition-colors",
                style: "color:#C9C9C9" %>
        </li>
      </ul>
    </div>

    <%# Col 3 — Honor %>
    <div>
      <div class="text-eyebrow mb-3.5" style="color:#C9C9C9">Honor</div>
      <ul class="list-none p-0 m-0 space-y-1.5">
        <li class="text-sm">
          <%= link_to "Plant a tree", new_tree_path,
                class: "no-underline hover:text-white transition-colors",
                style: "color:#C9C9C9" %>
        </li>
        <li class="text-sm">
          <%= link_to "Share a memory", new_memory_path,
                class: "no-underline hover:text-white transition-colors",
                style: "color:#C9C9C9" %>
        </li>
        <li class="text-sm">
          <%= link_to "Adopt a hive", new_bee_hive_path,
                class: "no-underline hover:text-white transition-colors",
                style: "color:#C9C9C9" %>
        </li>
        <li class="text-sm">
          <%= link_to "Funds", funds_path,
                class: "no-underline hover:text-white transition-colors",
                style: "color:#C9C9C9" %>
        </li>
      </ul>
    </div>

    <%# Col 4 — More %>
    <div>
      <div class="text-eyebrow mb-3.5" style="color:#C9C9C9">More</div>
      <ul class="list-none p-0 m-0 space-y-1.5">
        <li class="text-sm">
          <%= link_to "Submit photos", new_photo_submission_path,
                class: "no-underline hover:text-white transition-colors",
                style: "color:#C9C9C9" %>
        </li>
        <li class="text-sm">
          <%= link_to "Order the book", "https://christopherquentin.fillout.com/book",
                target: "_blank", rel: "noopener",
                class: "no-underline hover:text-white transition-colors",
                style: "color:#C9C9C9" %>
        </li>
        <li class="text-sm">
          <%= link_to "Share a tribute", new_tribute_path,
                class: "no-underline hover:text-white transition-colors",
                style: "color:#C9C9C9" %>
        </li>
        <li class="text-sm">
          <% if user_signed_in? %>
            <%= link_to "Sign out", destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "no-underline hover:text-white transition-colors",
                  style: "color:#C9C9C9" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path,
                  class: "no-underline hover:text-white transition-colors",
                  style: "color:#C9C9C9" %>
          <% end %>
        </li>
      </ul>
    </div>

  </div>

  <%# Bottom bar %>
  <div class="max-w-[1180px] mx-auto px-6 lg:px-10 mt-14 pt-6 border-t border-white/12 flex justify-between text-[13px] font-mono uppercase tracking-[0.1em]" style="color:#C9C9C9">
    <span>&copy; <%= Date.current.year %> Christopher Quentin Memorial</span>
    <span>1984 – 2020</span>
  </div>
</footer>

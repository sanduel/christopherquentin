<div data-controller="tribute-modal">
  <%= link_to tribute_path(tribute), data: { action: "tribute-modal#open" },
        class: "block text-left no-underline cursor-pointer h-full" do %>
    <article class="bg-white-bg rounded-[5px] p-[34px_30px] flex flex-col h-full shadow-[0_1px_2px_rgba(17,17,17,0.05)] hover:shadow-[0_4px_16px_rgba(17,17,17,0.10)] transition-shadow break-inside-avoid border border-ink/8">
      <% if tribute.video? %>
        <div class="relative aspect-video rounded-[3px] overflow-hidden bg-ink/5">
          <%= image_tag tribute.youtube_thumbnail_url, alt: "", loading: "lazy",
                class: "absolute inset-0 w-full h-full object-cover" %>
          <span class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
            <span class="flex items-center justify-center w-[58px] h-[58px] rounded-full bg-ink/70">
              <svg viewBox="0 0 24 24" fill="white" class="w-6 h-6 ml-0.5"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </span>
        </div>
        <% if tribute.content.present? %>
          <p class="font-serif text-[16px] leading-[1.5] text-quote mt-4 mb-0 flex-grow">
            <%= truncate(tribute.content.to_s, length: 140) %>
          </p>
        <% end %>
      <% else %>
        <span class="font-serif text-[50px] leading-[0.5] text-accent h-[30px]" aria-hidden="true">&ldquo;</span>
        <p class="font-serif text-[19px] leading-[1.5] text-quote mt-3.5 mb-0 flex-grow">
          <%= truncate(tribute.content.to_s, length: 240) %>
        </p>
      <% end %>
      <div class="border-t border-ink/10 mt-6 pt-4">
        <div class="font-bold text-[15px] text-ink"><%= tribute.name %></div>
        <% if tribute.relationship.present? %>
          <div class="font-mono text-[11px] tracking-[0.16em] uppercase text-accent mt-1"><%= tribute.relationship %></div>
        <% end %>
      </div>
    </article>
  <% end %>

  <dialog data-tribute-modal-target="dialog"
          data-action="click->tribute-modal#backdropClose close->tribute-modal#reset"
          aria-labelledby="<%= dom_id(tribute, :modal_name) %>"
          class="rounded-[5px] bg-white-bg max-w-[640px] w-[92vw] max-h-[88vh] p-0 m-auto backdrop:bg-ink/40">
    <div class="flex justify-end px-5 pt-4">
      <button type="button" data-action="tribute-modal#close"
              aria-label="Close"
              class="text-mono hover:text-accent text-[26px] leading-none cursor-pointer transition-colors">&times;</button>
    </div>

    <div class="px-8 pb-9 pt-1 overflow-y-auto max-h-[calc(88vh-56px)]">
      <% if tribute.video? %>
        <div class="aspect-video w-full rounded-[3px] overflow-hidden bg-ink mb-7">
          <iframe data-tribute-modal-target="frame"
                  data-src="<%= tribute.youtube_embed_url %>"
                  class="w-full h-full" frameborder="0" allowfullscreen
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  title="Tribute video from <%= tribute.name %>"></iframe>
        </div>
        <% if tribute.content.present? %>
          <p class="font-serif text-[18px] leading-[1.55] text-quote m-0 whitespace-pre-line"><%= tribute.content %></p>
        <% end %>
        <div class="mt-7 pt-5 border-t border-ink/10">
          <div id="<%= dom_id(tribute, :modal_name) %>" class="font-bold text-[16px] text-ink"><%= tribute.name %></div>
          <% if tribute.relationship.present? %>
            <div class="font-mono text-[12px] tracking-[0.18em] uppercase text-accent mt-1.5"><%= tribute.relationship %></div>
          <% end %>
        </div>
      <% else %>
        <% if tribute.photo.attached? %>
          <%# Loaded by the Stimulus controller when the modal opens, so the index
              doesn't download every tribute's photo on page load. %>
          <img data-tribute-modal-target="image"
               data-src="<%= url_for(tribute.photo.variant(resize_to_limit: [1200, 1200])) %>"
               alt="" loading="lazy"
               class="w-full aspect-[16/9] object-cover rounded-[3px] mb-8 bg-ink/5">
        <% end %>

        <span class="block font-serif text-[80px] leading-none text-accent -mb-6" aria-hidden="true">&ldquo;</span>
        <blockquote class="mt-1 m-0">
          <p class="font-serif text-[20px] md:text-[22px] leading-[1.55] text-quote m-0 whitespace-pre-line"><%= tribute.content %></p>
          <footer class="mt-8 pt-5 border-t border-ink/10">
            <div id="<%= dom_id(tribute, :modal_name) %>" class="font-bold text-[16px] text-ink">&mdash; <%= tribute.name %></div>
            <% if tribute.relationship.present? %>
              <div class="font-mono text-[12px] tracking-[0.18em] uppercase text-accent mt-1.5"><%= tribute.relationship %></div>
            <% end %>
          </footer>
        </blockquote>
      <% end %>
    </div>
  </dialog>
</div>

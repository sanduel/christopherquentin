<% content_for :title, "Submit Photos — Christopher Quentin" %>

<section class="max-w-[760px] mx-auto px-6 lg:px-10 pt-20 pb-24">
  <div class="flex items-center gap-3">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">Photos · Submit</span>
  </div>

  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(40px, 5.5vw, 64px); line-height: 1.0;">
    Submit a photo.
  </h1>

  <p class="text-[16px] text-muted mt-5 max-w-[560px]">
    Share your photos of Christopher. They'll be reviewed before being added to the gallery.
  </p>

  <%= form_with url: submit_photos_path, method: :post, class: "space-y-6 mt-12", multipart: true do |f| %>
    <% if flash[:alert] %>
      <div class="bg-band border-l-2 border-[#b91c1c] text-[#b91c1c] px-4 py-3 text-sm"><%= flash[:alert] %></div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= label_tag :submitter_name, "Your name", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
        <%= text_field_tag :submitter_name, @submitter_name, required: true,
              placeholder: "Full name",
              class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      </div>
      <div>
        <%= label_tag :submitter_email, "Email", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
        <%= email_field_tag :submitter_email, @submitter_email, required: true,
              placeholder: "you@example.com",
              class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      </div>
    </div>

    <div>
      <%= label_tag :photos, "Photos", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= file_field_tag "photos[]", multiple: true, accept: "image/*", required: true,
            class: "block text-sm text-ink file:mr-4 file:py-2 file:px-4 file:rounded-md file:border file:border-ink/22 file:bg-white-bg file:text-ink file:font-medium hover:file:border-ink" %>
      <p class="text-[13px] text-muted mt-1.5">You can select multiple photos at once.</p>
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <%= submit_tag "Submit photos",
            class: "bg-ink text-white-bg no-underline text-[15px] font-semibold py-[15px] px-7 rounded-md hover:bg-ink-deep transition-colors cursor-pointer border-0" %>
      <%= link_to "Cancel", gallery_path, class: "self-center text-accent text-[15px] font-semibold no-underline hover:opacity-70 transition-opacity" %>
    </div>
  <% end %>
</section>

<section class="px-6 lg:px-14 py-12 lg:py-20 max-w-[460px] mx-auto">
  <%= musical_eyebrow("Op. — · Sign in", with_rule: true) %>
  <h1 class="font-serif text-4xl md:text-5xl text-ink mt-3 font-normal leading-tight">
    Welcome <em class="font-serif italic text-moss">back</em>.
  </h1>
  <p class="text-[17px] text-ink/65 mt-3">
    Sign in to your account to continue.
  </p>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5 mt-10" }) do |f| %>
    <div>
      <%= f.label :email, class: "text-eyebrow text-sage block mb-1" %>
      <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :password, class: "text-eyebrow text-sage block mb-1" %>
      <%= f.password_field :password,
            autocomplete: "current-password",
            required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div>
        <label class="inline-flex items-center gap-2 text-sm text-ink/70">
          <%= f.check_box :remember_me, class: "rounded border-ink/20" %>
          Remember me
        </label>
      </div>
    <% end %>

    <%= f.submit "Sign in",
          class: "bg-moss text-cream rounded-full px-6 py-3 text-sm font-medium hover:bg-ink transition-colors cursor-pointer w-full" %>
  <% end %>

  <div class="mt-8 text-sm text-ink/65 text-center space-y-2">
    <p><%= link_to "Forgot your password?", new_user_password_path, class: "underline underline-offset-2 hover:text-ink transition-colors" %></p>
    <p>Don't have an account? <%= link_to "Sign up", new_user_registration_path, class: "underline underline-offset-2 hover:text-ink transition-colors" %></p>
  </div>
</section>

<div class="max-w-md mx-auto">
  <h1 class="text-3xl font-title text-stone-800 mb-8">Sign In</h1>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password", required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center">
        <%= f.check_box :remember_me, class: "mr-2 rounded border-stone-300 text-blue-700 focus:ring-blue-600" %>
        <%= f.label :remember_me, class: "text-sm text-stone-600" %>
      </div>
    <% end %>

    <%= f.submit "Sign in", class: "w-full px-4 py-3 bg-blue-800 text-white rounded-lg hover:bg-blue-700 transition cursor-pointer font-medium" %>
  <% end %>

  <div class="mt-6 text-center text-sm text-stone-500 space-y-1">
    <p><%= link_to "Forgot your password?", new_user_password_path, class: "text-blue-800 hover:text-blue-700" %></p>
    <p>Don't have an account? <%= link_to "Sign up", new_user_registration_path, class: "text-blue-800 hover:text-blue-700" %></p>
  </div>
</div>

<section class="px-6 lg:px-14 py-12 lg:py-20 max-w-[460px] mx-auto">
  <%= musical_eyebrow("Op. — · Sign up", with_rule: true) %>
  <h1 class="font-serif text-4xl md:text-5xl text-ink mt-3 font-normal leading-tight">
    Create your <em class="font-serif italic text-moss">account</em>.
  </h1>
  <p class="text-[17px] text-ink/65 mt-3">
    Join to plant trees, follow tributes, and be part of the garden.
  </p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5 mt-10" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_field :name,
            autofocus: true,
            required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :email, class: "text-eyebrow text-sage block mb-1" %>
      <%= f.email_field :email,
            autocomplete: "email",
            required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :password, class: "text-eyebrow text-sage block mb-1" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-sage/70 mb-1"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password,
            autocomplete: "new-password",
            required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "text-eyebrow text-sage block mb-1" %>
      <%= f.password_field :password_confirmation,
            autocomplete: "new-password",
            required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <%= f.submit "Sign up",
          class: "bg-moss text-cream rounded-full px-6 py-3 text-sm font-medium hover:bg-ink transition-colors cursor-pointer w-full" %>
  <% end %>

  <div class="mt-8 text-sm text-ink/65 text-center">
    <p>Already have an account? <%= link_to "Sign in", new_user_session_path, class: "underline underline-offset-2 hover:text-ink transition-colors" %></p>
  </div>
</section>

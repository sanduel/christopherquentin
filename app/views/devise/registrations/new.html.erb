<section class="max-w-[460px] mx-auto px-6 lg:px-10 pt-20 pb-24">
  <%# Eyebrow %>
  <div class="flex items-center gap-3">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">Account · Create</span>
  </div>

  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(36px, 5vw, 56px); line-height: 1.0;">
    Sign up.
  </h1>

  <p class="text-[16px] text-muted mt-5">Join to plant trees, follow tributes, and be part of the memorial.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6 mt-12" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.text_field :name,
            autofocus: true,
            required: true,
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
    </div>

    <div>
      <%= f.label :email, class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.email_field :email,
            autocomplete: "email",
            required: true,
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
    </div>

    <div>
      <%= f.label :password, class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <% if @minimum_password_length %>
        <p class="text-[13px] text-muted mb-2"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password,
            autocomplete: "new-password",
            required: true,
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.password_field :password_confirmation,
            autocomplete: "new-password",
            required: true,
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
    </div>

    <%= f.submit "Sign up",
          class: "bg-ink text-white-bg no-underline text-[15px] font-semibold py-[15px] px-7 rounded-md hover:bg-ink-deep transition-colors cursor-pointer border-0 w-full" %>
  <% end %>

  <div class="mt-10">
    <p class="text-[14px] text-muted">
      Already have an account?
      <%= link_to "Sign in", new_user_session_path,
            class: "text-accent font-semibold no-underline hover:opacity-70 transition-opacity" %>
    </p>
  </div>
</section>

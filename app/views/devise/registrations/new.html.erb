<div class="max-w-md mx-auto">
  <h1 class="text-3xl font-title text-stone-800 mb-8">Sign Up</h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :name, autofocus: true, required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.email_field :email, autocomplete: "email", required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-stone-400 mb-1"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <%= f.submit "Sign up", class: "w-full px-4 py-3 bg-blue-800 text-white rounded-lg hover:bg-blue-700 transition cursor-pointer font-medium" %>
  <% end %>

  <p class="mt-6 text-center text-sm text-stone-500">
    Already have an account? <%= link_to "Sign in", new_user_session_path, class: "text-blue-800 hover:text-blue-700" %>
  </p>
</div>

<% content_for :title, "Adopt a Bee Hive — Christopher Quentin" %>

<section class="px-6 lg:px-14 py-12 lg:py-16 max-w-[760px] mx-auto">
  <%= musical_eyebrow("Op. VI.iii · Adopt a bee hive", with_rule: true) %>
  <h1 class="font-serif text-4xl md:text-5xl lg:text-[64px] font-normal leading-tight tracking-tight text-ink mt-3">
    Adopt a <em class="font-serif italic text-moss">bee hive</em>.
  </h1>
  <p class="text-[17px] text-ink/65 mt-3 max-w-[560px]">
    Christopher loved bees. Register a hive in his memory and add it to the map.
  </p>

  <%= form_with model: @bee_hive, class: "space-y-5 mt-10", multipart: true do |f| %>
    <% if @bee_hive.errors.any? %>
      <div class="bg-linen border-l-2 border-rose text-rose p-3 text-sm">
        <ul>
          <% @bee_hive.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Your name", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_field :name, required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :email, "Email", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.email_field :email,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :address, "Where is the hive?", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_field :address, required: true,
            placeholder: "e.g. 123 Main St, Ann Arbor, MI",
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
      <p class="text-xs text-ink/40 mt-1">Address, city, and state/country. Geocoded to place a pin on the map.</p>
    </div>

    <div>
      <%= f.label :story, "Tell us about this hive (optional)", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_area :story, rows: 4,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :photo, "Photo (optional)", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.file_field :photo, accept: "image/*", class: "block" %>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Register hive →",
            class: "bg-moss text-cream rounded-full px-6 py-3 text-sm font-medium hover:bg-ink transition-colors cursor-pointer" %>
      <%= link_to "Cancel", bee_hives_path,
            class: "text-moss text-sm font-medium hover:underline no-underline self-center" %>
    </div>
  <% end %>
</section>

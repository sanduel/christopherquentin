<% content_for(:title, "Add a Bee Hive — Christopher Quentin") %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-4xl font-title text-stone-800 mb-2">Add a Bee Hive</h1>
  <p class="text-stone-500 mb-8">Christopher loved bees. Register a hive in his memory and add it to the map.</p>

  <%= form_with model: @bee_hive, class: "space-y-6" do |f| %>
    <% if @bee_hive.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4">
        <ul class="text-red-700 text-sm">
          <% @bee_hive.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Your Name", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :name, required: true, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :email, "Your Email", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.email_field :email, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :address, "Where is the hive?", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :address, required: true, placeholder: "e.g. 123 Main St, Ann Arbor, MI", class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
      <p class="text-xs text-stone-400 mt-1">Address, city, and state/country. Geocoded to place a pin on the map.</p>
    </div>

    <div>
      <%= f.label :story, "Tell us about this hive (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_area :story, rows: 4, class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" %>
    </div>

    <div>
      <%= f.label :photo, "Photo (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.file_field :photo, accept: "image/*", class: "text-sm text-stone-600" %>
    </div>

    <%= f.submit "Submit Hive", class: "w-full px-4 py-3 bg-yellow-700 text-white rounded-lg hover:bg-yellow-600 transition cursor-pointer font-medium" %>
  <% end %>
</div>

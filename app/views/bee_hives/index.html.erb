<% content_for(:title, "Bee Hives — Christopher Quentin") %>

<section class="max-w-[1180px] mx-auto px-6 lg:px-10 pt-20 pb-12">
  <div class="flex items-center gap-3">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">Bee Hives · a living legacy</span>
  </div>
  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(40px, 5.5vw, 72px); line-height: 1.0;">
    A living map of pollinators.
  </h1>
  <p class="text-[16px] text-muted mt-5 max-w-[640px]">
    Christopher cared deeply about pollinators. Each hive registered here adds to the
    <%= link_to "unified map", map_path, class: "text-accent hover:opacity-70 transition-opacity" %>.
  </p>
</section>

<section class="max-w-[1180px] mx-auto px-6 lg:px-10 pb-16">
  <% if @bee_hives.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @bee_hives.each do |hive| %>
        <article class="bg-white-bg border border-ink/8 rounded-[5px] overflow-hidden flex flex-col shadow-[0_1px_2px_rgba(17,17,17,0.04)]">
          <% if hive.photo.attached? %>
            <%= image_tag hive.photo.variant(resize_to_limit: [600, 450]), class: "w-full aspect-[4/3] object-cover" %>
          <% else %>
            <div class="w-full aspect-[4/3] rounded-t-[5px] relative"
                 style="background: repeating-linear-gradient(135deg, #E6E6E6 0 11px, #EFEFEF 11px 22px);">
              <span class="absolute left-3.5 bottom-3 font-mono text-[11px] tracking-[0.1em] text-ink/40">[ HIVE ]</span>
            </div>
          <% end %>
          <div class="p-6 flex flex-col flex-grow">
            <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-mono"><%= hive.address %></span>
            <h3 class="font-serif font-medium text-[22px] text-ink mt-2.5 leading-tight">
              <%= link_to hive.name, bee_hive_path(hive), class: "no-underline text-ink hover:text-accent" %>
            </h3>
            <% if hive.story.present? %>
              <p class="text-[15px] text-muted leading-[1.55] mt-3 flex-grow"><%= truncate(hive.story.to_s, length: 120) %></p>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <p class="font-serif italic text-[22px] text-muted">No hives yet. Be the first to register one in Christopher&rsquo;s memory.</p>
    </div>
  <% end %>
</section>

<section class="bg-band py-16">
  <div class="max-w-[1180px] mx-auto px-6 lg:px-10 flex flex-col sm:flex-row items-center justify-between gap-6">
    <div>
      <h2 class="font-serif font-medium text-[28px] text-ink m-0">Adopt a hive in his honor.</h2>
      <p class="text-[16px] text-muted mt-2">Register it in Christopher&rsquo;s name and add it to the memorial map.</p>
    </div>
    <%= link_to "Submit a hive", new_bee_hive_path,
          class: "shrink-0 inline-block bg-ink text-white-bg rounded-md px-6 py-3 text-[15px] font-medium no-underline hover:opacity-80 transition-opacity" %>
  </div>
</section>

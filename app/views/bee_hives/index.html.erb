<% content_for(:title, "Bee Hives — Christopher Quentin") %>

<div class="max-w-6xl mx-auto">
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-4xl font-title text-stone-800">Bee Hives</h1>
    <%= link_to "Add a Hive", new_bee_hive_path, class: "px-4 py-2 bg-yellow-700 text-white rounded hover:bg-yellow-600 transition" %>
  </div>

  <p class="text-stone-600 leading-relaxed mb-8">
    Christopher cared deeply about pollinators. Each hive registered here adds to the unified map at
    <%= link_to "/map", map_path, class: "text-blue-800 hover:text-blue-700 underline" %>.
  </p>

  <% if @bee_hives.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @bee_hives.each do |hive| %>
        <div class="bg-white p-6 rounded-lg shadow-sm border border-stone-200">
          <% if hive.photo.attached? %>
            <div class="mb-3">
              <%= image_tag hive.photo.variant(resize_to_limit: [400, 250]), class: "rounded-lg w-full object-cover" %>
            </div>
          <% end %>
          <h3 class="text-lg font-medium text-stone-800"><%= hive.name %></h3>
          <p class="text-sm text-stone-400 mb-2"><%= hive.address %></p>
          <% if hive.story.present? %>
            <p class="text-stone-600 text-sm"><%= truncate(hive.story, length: 200) %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-stone-400 italic text-center py-8">No hives yet. Be the first to register one in Christopher&rsquo;s memory.</p>
  <% end %>
</div>

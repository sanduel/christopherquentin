<% content_for(:title, "Bee Hives — Christopher Quentin") %>

<section class="px-6 lg:px-14 pt-12 pb-8">
  <%= musical_eyebrow("Op. X · Bee Hives", with_rule: true) %>
  <h1 class="font-serif text-5xl md:text-6xl lg:text-[80px] font-normal leading-tight tracking-tight text-ink mt-3">
    A living map of <em class="font-serif italic text-moss">pollinators</em>.
  </h1>
  <p class="text-[17px] text-ink/65 mt-3 max-w-[640px]">
    Christopher cared deeply about pollinators. Each hive registered here adds to the
    <%= link_to "unified map", map_path, class: "text-moss hover:underline" %>.
  </p>
</section>

<section class="px-6 lg:px-14 pb-16">
  <% if @bee_hives.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @bee_hives.each do |hive| %>
        <article class="bg-white rounded-md border border-ink/8 shadow-card overflow-hidden flex flex-col">
          <% if hive.photo.attached? %>
            <div class="aspect-[4/3] overflow-hidden">
              <%= image_tag hive.photo.variant(resize_to_limit: [600, 450]), class: "w-full h-full object-cover" %>
            </div>
          <% else %>
            <div class="aspect-[4/3] relative"
                 style="background: linear-gradient(160deg, rgba(58,82,64,0.22), rgba(90,122,94,0.30)), repeating-linear-gradient(45deg, rgba(58,82,64,0.07) 0 14px, transparent 14px 28px);">
              <div class="absolute bottom-3 left-3 text-eyebrow text-cream mix-blend-difference">[ hive ]</div>
            </div>
          <% end %>

          <div class="p-5 flex flex-col flex-1">
            <h3 class="font-serif text-[22px] font-medium leading-snug text-ink"><%= hive.name %></h3>
            <p class="text-eyebrow text-sage mt-1.5"><%= hive.address %></p>
            <% if hive.story.present? %>
              <p class="text-sm text-ink/70 leading-relaxed mt-3 flex-1"><%= truncate(hive.story, length: 200) %></p>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <p class="font-serif italic text-2xl text-ink/50">No hives yet. Be the first to register one in Christopher&rsquo;s memory.</p>
    </div>
  <% end %>
</section>

<section class="bg-linen px-6 lg:px-14 py-16">
  <div class="max-w-[720px] mx-auto text-center">
    <h2 class="font-serif text-3xl md:text-4xl text-ink mt-0">
      Have a hive to share?
    </h2>
    <p class="text-[17px] text-ink/65 mt-3">Register it in Christopher&rsquo;s name and add it to the memorial map.</p>
    <%= link_to "+ Submit a hive", new_bee_hive_path,
          class: "inline-block mt-6 bg-moss text-cream rounded-full px-6 py-3 text-sm font-medium no-underline hover:bg-ink transition-colors" %>
  </div>
</section>

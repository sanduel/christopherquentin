<%# Year group: left column with the year (Newsreader 56px ink), right column with items.
    Locals: year (int or nil), items (array of PressItem) %>
<div data-year-group class="grid grid-cols-1 lg:grid-cols-[180px_1fr] gap-6 lg:gap-12 py-8 border-t border-ink/8">
  <div>
    <h2 class="font-serif font-medium text-[56px] text-ink leading-none m-0 tracking-[-0.02em] lg:sticky lg:top-24">
      <%= year || "—" %>
    </h2>
  </div>
  <div>
    <% items.each do |item| %>
      <%= render "pages/news/press_item", item: item %>
    <% end %>
  </div>
</div>

    ["Education", "Royal College of Music · Dartmouth College"],
    ["Music Director of", "Jæren Symfoniorkester, 2019 — 2020"],
    ["Started career at", "Bayerische Staatsoper, Munich"],
    ["Made Stavanger his home", "2019"],
  ].each do |label, value| %>

<%# Renders one RepertoireGroup list. Locals: title (string), groups (array of Repertoire::Group) %>
<div>
  <h3 class="font-serif font-medium text-[26px] text-ink mt-0 mb-6 tracking-[-0.01em]"><%= title %></h3>
  <dl class="space-y-4">
    <% groups.each do |g| %>
      <div class="grid grid-cols-[1fr_2fr] gap-4 items-baseline pb-4 border-b border-ink/8">
        <dt class="font-serif italic text-[19px] text-ink m-0"><%= g.composer %></dt>
        <dd class="text-[15px] text-muted leading-relaxed m-0">
          <%= g.works.join(" · ") %>
        </dd>
      </div>
    <% end %>
  </dl>
</div>

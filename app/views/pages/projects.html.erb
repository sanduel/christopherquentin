<% content_for :title, "Projects — Christopher Quentin" %>

<%# Hero %>
<section class="max-w-[1180px] mx-auto px-6 lg:px-10 pt-20 pb-10">
  <div class="flex items-center gap-3">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">Projects</span>
  </div>
  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(46px, 6.4vw, 80px); line-height: 0.98;">
    Work in <span class="italic text-accent">Chris'</span> memory.
  </h1>
  <p class="text-[16px] text-muted mt-5 max-w-[640px]">
    Christopher gave so much in his 36 years. These projects continue his impact —
    music, environmental action, community.
  </p>
  <nav class="mt-6 flex flex-wrap gap-3 text-[14px]">
    <a href="#trees" class="text-accent font-semibold no-underline hover:opacity-70 transition-opacity">Memorial Trees</a>
    <span aria-hidden="true" class="text-ink/30">·</span>
    <a href="#funds" class="text-accent font-semibold no-underline hover:opacity-70 transition-opacity">Memorial Funds</a>
    <span aria-hidden="true" class="text-ink/30">·</span>
    <%= link_to "Recipes", recipes_path, class: "text-accent font-semibold no-underline hover:opacity-70 transition-opacity" %>
    <span aria-hidden="true" class="text-ink/30">·</span>
    <%= link_to "Bee Hives", bee_hives_path, class: "text-accent font-semibold no-underline hover:opacity-70 transition-opacity" %>
    <span aria-hidden="true" class="text-ink/30">·</span>
    <%= link_to "Zero Waste", zero_waste_path, class: "text-accent font-semibold no-underline hover:opacity-70 transition-opacity" %>
  </nav>
</section>

<%# Trees section %>
<section id="trees" class="scroll-mt-24 border-t border-ink/10 pt-12">
  <div class="max-w-[1180px] mx-auto px-6 lg:px-10">
    <div class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">Memorial Trees</div>
  </div>

  <%= render "trees/world_map_placeholder", trees: @trees, stats: @stats %>

  <div class="max-w-[1180px] mx-auto px-6 lg:px-10 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <div data-controller="modal">
        <div class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent mb-4">Plant a tree</div>
        <h3 class="font-serif font-medium text-[28px] text-ink mt-0 mb-4 tracking-[-0.01em]">
          Add a tree to the map.
        </h3>
        <p class="text-[16px] text-muted mb-6 max-w-[440px]">
          Plant a tree in Chris' memory and pin it to the living map.
        </p>
        <button type="button" data-action="modal#open"
                class="bg-ink text-white-bg text-[15px] font-semibold py-[15px] px-7 rounded-md cursor-pointer hover:bg-ink-deep transition-colors border-0">
          Add a tree to the map →
        </button>

        <dialog data-modal-target="dialog" data-action="click->modal#backdrop"
                class="rounded-[5px] bg-white-bg max-w-[560px] w-[92vw] p-0 m-auto backdrop:bg-ink/40">
          <div class="flex items-start justify-between px-8 pt-6 pb-4 border-b border-ink/8">
            <h2 class="font-serif font-medium text-[28px] text-ink m-0 tracking-[-0.01em]">Add a tree to the map</h2>
            <button type="button" data-action="modal#close" aria-label="Close"
                    class="text-ink/40 hover:text-ink text-3xl leading-none cursor-pointer bg-transparent border-0">&times;</button>
          </div>
          <div class="p-8">
            <%= render "trees/add_tree_form", tree: @new_tree %>
          </div>
        </dialog>
      </div>
      <div class="aspect-[4/5] rounded-[3px] border border-ink/8 relative overflow-hidden"
           style="background: repeating-linear-gradient(135deg, #E6E6E6 0 11px, #EFEFEF 11px 22px);">
        <div class="absolute bottom-3 left-3 font-mono text-[10px] tracking-[0.14em] uppercase text-mono">
          [ the first Chris tree — Ann Arbor, planted by his parents ]
        </div>
      </div>
    </div>
  </div>
</section>

<%# Funds section %>
<section id="funds" class="scroll-mt-24 border-t border-ink/10 bg-band py-16 lg:py-20">
  <div class="max-w-[1180px] mx-auto px-6 lg:px-10">
    <div class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">Memorial Funds</div>
    <h2 class="font-serif font-medium tracking-[-0.01em] text-ink mt-4"
        style="font-size: clamp(34px, 4.6vw, 58px);">
      Bees, waste, water, music.
    </h2>

    <div class="font-serif text-[19px] leading-relaxed text-ink mt-8 space-y-5 max-w-[760px]">
      <p>Join us in continuing Christopher's impact.</p>
      <p>
        The McMullen family thoughtfully determines grantees based on initiatives that keep Christopher's
        passions alive. Grant amounts are considered in the context of total fund value. Reports of grant
        recipients are shared here on the memorial website.
      </p>
      <p>
        If you have projects that need support — starting a beehive, planting a tree, hosting a concert —
        please don't hesitate to get in touch.
      </p>
      <p class="text-muted">You can also contribute to specific projects below.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-10">
      <article class="bg-white-bg border border-ink/8 rounded-[5px] p-[30px_26px_28px] flex flex-col shadow-[0_1px_2px_rgba(17,17,17,0.04)]">
        <span class="block w-7 h-0.5 bg-accent mb-6"></span>
        <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-accent">I · Bees</span>
        <h3 class="font-serif font-medium text-[25px] text-ink mt-3 mb-3.5 tracking-[-0.01em]">Pollinators</h3>
        <p class="text-[15px] leading-[1.55] text-muted m-0 flex-grow">
          Supporting beekeeping projects and pollinator conservation across his nine countries.
        </p>
      </article>

      <article class="bg-white-bg border border-ink/8 rounded-[5px] p-[30px_26px_28px] flex flex-col shadow-[0_1px_2px_rgba(17,17,17,0.04)]">
        <span class="block w-7 h-0.5 bg-accent mb-6"></span>
        <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-accent">II · Water</span>
        <h3 class="font-serif font-medium text-[25px] text-ink mt-3 mb-3.5 tracking-[-0.01em]">Water</h3>
        <p class="text-[15px] leading-[1.55] text-muted m-0 flex-grow">
          Water-related environmental initiatives — restoration, conservation, access.
        </p>
      </article>

      <article class="bg-white-bg border border-ink/8 rounded-[5px] p-[30px_26px_28px] flex flex-col shadow-[0_1px_2px_rgba(17,17,17,0.04)]">
        <span class="block w-7 h-0.5 bg-accent mb-6"></span>
        <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-accent">III · Zero Waste</span>
        <h3 class="font-serif font-medium text-[25px] text-ink mt-3 mb-3.5 tracking-[-0.01em]">Zero Waste</h3>
        <p class="text-[15px] leading-[1.55] text-muted m-0 flex-grow">
          Waste reduction and sustainability efforts — the same week-long pledge his friends made for him.
        </p>
        <%= link_to "About Zero Waste Week →", zero_waste_path,
              class: "text-accent text-[15px] font-semibold mt-4 no-underline hover:opacity-70 transition-opacity" %>
      </article>

      <article class="bg-white-bg border border-ink/8 rounded-[5px] p-[30px_26px_28px] flex flex-col shadow-[0_1px_2px_rgba(17,17,17,0.04)]">
        <span class="block w-7 h-0.5 bg-accent mb-6"></span>
        <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-accent">IV · Dartmouth Conducting Endowment</span>
        <h3 class="font-serif font-medium text-[25px] text-ink mt-3 mb-3.5 tracking-[-0.01em]">Dartmouth Conducting Endowment</h3>
        <div class="text-[15px] leading-[1.55] text-muted flex-grow space-y-3">
          <p class="m-0">
            Christopher (aka 'Zeke') spent formative years at Dartmouth. He flourished as a music major
            and Senior Fellow, as a member of the Chamber Singers and Handel Society, and through a term
            abroad studying music.
          </p>
          <p class="m-0">
            We honor him through a gift that will strengthen the College and seed the next generation
            of conductors.
          </p>
        </div>
        <div class="mt-5 space-y-2 text-[14px]">
          <p class="m-0">
            <%= link_to "Donate by credit card or PayPal",
                  "https://securelb.imodules.com/s/1353/events/events.aspx?sid=1353&gid=431&pgid=15529&cid=38949&bledit=1&dids=508&appealcode=campaignws",
                  target: "_blank", rel: "noopener",
                  class: "text-accent font-semibold hover:opacity-70 no-underline transition-opacity" %>
          </p>
          <p class="m-0">
            <%= link_to "Wire transfer", "https://dartgo.org/wiretransfer",
                  target: "_blank", rel: "noopener",
                  class: "text-accent font-semibold hover:opacity-70 no-underline transition-opacity" %>
            — enter "Christopher McMullen-Laird Memorial Fund" in the Gift Allocation box.
          </p>
          <p class="text-mono text-[12px] leading-relaxed mt-3 m-0">
            By check: payable to "Trustees of Dartmouth College", directed to Gift Recording Office,
            6066 Development Office, Hanover, NH 03755-4400. Reference "Christopher McMullen-Laird
            Memorial Fund". Toll free: 1-800-490-7010.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<%# Other ways in %>
<section class="border-t border-ink/10 py-16">
  <div class="max-w-[1180px] mx-auto px-6 lg:px-10">
    <div class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent mb-8">Other ways in</div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <% [
        { title: "Adopt a Bee Hive", body: "Pollinators were one of his loves. Register a hive on the unified map.",
          cta: "Adopt a hive →", path: new_bee_hive_path },
        { title: "Share a Memory", body: "A photo, a story, an audio clip — contribute to the timeline.",
          cta: "Share a memory →", path: new_memory_path },
        { title: "Cook a recipe", body: "Recipes Chris cooked or that remind people of him.",
          cta: "Browse recipes →", path: recipes_path },
      ].each do |card| %>
        <%= link_to card[:path], class: "group block no-underline" do %>
          <article class="bg-white-bg border border-ink/8 rounded-[5px] p-[30px_26px_28px] flex flex-col shadow-[0_1px_2px_rgba(17,17,17,0.04)] hover:border-ink/15 transition-colors">
            <span class="block w-7 h-0.5 bg-accent mb-6"></span>
            <h3 class="font-serif font-medium text-[22px] text-ink mt-0 mb-3 tracking-[-0.01em]"><%= card[:title] %></h3>
            <p class="text-[15px] leading-[1.55] text-muted m-0 flex-grow"><%= card[:body] %></p>
            <span class="text-accent text-[15px] font-semibold mt-5 group-hover:opacity-70 transition-opacity"><%= card[:cta] %></span>
          </article>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

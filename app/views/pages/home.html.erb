<% content_for :title, "Christopher Quentin McMullen-Laird — In Memoriam" %>

<%# Section 1 — Hero %>
<section class="max-w-[1180px] mx-auto px-6 lg:px-10 pt-20 pb-24">
  <div class="grid grid-cols-1 lg:grid-cols-[1.08fr_0.92fr] gap-10 lg:gap-16 items-start">
    <div>
      <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mb-0"
          style="font-size: clamp(40px, 5.4vw, 78px); line-height: 0.98;">
        Christopher<br>
        Quentin<br>
        McMullen-Laird
      </h1>

      <%# CTA pair: Share a memory primary (filled), Read his story secondary (outline) %>
      <div class="flex flex-wrap gap-3.5 mt-10">
        <button type="button"
                data-controller="share-modal-trigger" data-action="share-modal-trigger#open"
                class="bg-ink text-white-bg no-underline text-[15px] font-semibold py-[15px] px-7 rounded-md hover:bg-ink-deep transition-colors cursor-pointer">
          + Share a memory
        </button>
        <%= link_to "Read his story →", chris_path,
              class: "bg-transparent text-ink no-underline text-[15px] font-semibold py-[15px] px-7 rounded-md border border-ink/22 hover:border-ink transition-colors" %>
      </div>
    </div>

    <%# Portrait %>
    <div class="relative pb-10">
      <%= image_tag "chris-portrait.png",
            alt: "Christopher Quentin McMullen-Laird",
            class: "aspect-[1/1.04] w-full object-cover rounded-[3px]" %>
      <%# Floating rotated tag bottom-right %>
      <div class="absolute -right-1.5 -bottom-1.5 bg-white-bg px-4 py-3.5 rounded-[3px] shadow-[0_10px_30px_rgba(17,17,17,0.12)]"
           style="transform: rotate(2.5deg);">
        <span class="font-mono text-[11px] tracking-[0.1em] text-ink/55">[ London, 2019 ]</span>
      </div>
    </div>
  </div>
</section>

<%# Section 2 — Honor his memory %>
<section class="max-w-[1180px] mx-auto px-6 lg:px-10 pt-4 pb-24">
  <h2 class="font-serif font-medium text-[38px] tracking-[-0.01em] text-ink m-0 mb-9">Honor his memory</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-[18px]">
    <% [
      { eyebrow: "Plant", title: "Plant a Tree", body: "Add a tree to the living map of saplings planted in his memory across nine countries.", cta: "Plant a tree →", path: new_tree_path },
      { eyebrow: "Remember", title: "Share a Memory", body: "A photo, a story, an audio clip — contribute to the timeline of his life.", cta: "Share a memory →", path: new_memory_path },
      { eyebrow: "Pollinate", title: "Adopt a Bee Hive", body: "Register a hive on the unified map — pollinators were one of his loves.", cta: "Adopt a hive →", path: new_bee_hive_path },
      { eyebrow: "Sustain", title: "Support a Fund", body: "The McMullen-Laird Conservation Fund and four other funds carry his work forward.", cta: "Contribute →", path: funds_path },
    ].each do |card| %>
      <article class="bg-white-bg border border-ink/8 rounded-[5px] p-[30px_26px_28px] flex flex-col min-h-[268px] shadow-[0_1px_2px_rgba(17,17,17,0.04)]">
        <span class="block w-7 h-0.5 bg-accent mb-6"></span>
        <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-accent"><%= card[:eyebrow] %></span>
        <h3 class="font-serif font-medium text-[25px] text-ink mt-3 mb-3.5"><%= card[:title] %></h3>
        <p class="text-[15px] leading-[1.55] text-muted m-0 flex-grow"><%= card[:body] %></p>
        <%= link_to card[:cta], card[:path],
              class: "mt-[22px] no-underline text-accent text-[15px] font-semibold hover:opacity-70 transition-opacity" %>
      </article>
    <% end %>
  </div>
</section>

<%# Section 3 — Timeline band (gray) %>
<section class="bg-band py-[88px]">
  <div class="max-w-[1180px] mx-auto px-6 lg:px-10">
    <div class="flex flex-wrap justify-between items-end gap-6 mb-11">
      <div class="max-w-[640px]">
        <span class="font-mono text-[12px] tracking-[0.18em] uppercase text-accent">From the timeline</span>
        <h2 class="font-serif font-medium tracking-[-0.01em] text-ink mt-3.5 mb-2.5"
            style="font-size: clamp(34px, 4.6vw, 58px);">
          A life, kept by <span class="italic text-accent">many hands</span>.
        </h2>
        <p class="text-[16px] text-muted m-0">
          <%= pluralize(@memories_count, "memory", plural: "memories") %> so far. Browse them all, or add your own.
        </p>
      </div>
      <%= link_to "View full timeline →", memories_path,
            class: "whitespace-nowrap no-underline text-ink text-[15px] font-semibold py-3.5 px-6 rounded-md border border-ink/22 hover:border-ink transition-colors" %>
    </div>

    <%# Single memory card — most recent published memory if any %>
    <% if (memory = @timeline_preview_memories&.first) %>
      <article class="bg-white-bg rounded-[5px] p-[30px_32px] max-w-[460px] shadow-[0_1px_2px_rgba(17,17,17,0.05)]">
        <span class="font-mono text-[12px] tracking-[0.16em] uppercase text-accent"><%= l(memory.date, format: :memory) %></span>
        <p class="font-serif text-[20px] leading-[1.5] text-ink mt-4 mb-6"><%= truncate(memory.content.to_s, length: 220) %></p>
        <div class="border-t border-ink/10 pt-4 flex justify-between items-center">
          <span class="font-bold text-[15px]"><%= memory.display_name %></span>
          <span class="font-mono text-[11px] tracking-[0.16em] uppercase text-mono">
            <%= { "text" => "Letter", "photo" => "Photograph", "audio" => "Recording" }[memory.kind] %>
          </span>
        </div>
      </article>
    <% else %>
      <article class="bg-white-bg rounded-[5px] p-[30px_32px] max-w-[460px] text-center">
        <p class="font-serif italic text-[19px] text-muted m-0">No memories yet. Be the first to share one.</p>
      </article>
    <% end %>
  </div>
</section>

<%# Section 4 — Gatherings (conditional) %>
<% if @upcoming_events.any? %>
  <section class="max-w-[1180px] mx-auto px-6 lg:px-10 py-[90px]">
    <h2 class="font-serif font-medium tracking-[-0.01em] text-ink m-0 mb-10"
        style="font-size: clamp(34px, 4.6vw, 58px);">Memorial Events</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <% @upcoming_events.each do |event| %>
        <article class="bg-white-bg border border-ink/8 rounded-[5px] p-[30px_32px] shadow-[0_1px_2px_rgba(17,17,17,0.04)] flex flex-col">
          <div class="flex justify-between items-start gap-4 mb-5">
            <h3 class="font-serif font-medium text-[24px] text-ink m-0 leading-tight"><%= event.title %></h3>
            <span class="font-mono text-[11px] tracking-[0.14em] uppercase text-muted bg-band px-3 py-1.5 rounded-full whitespace-nowrap"><%= event.event_type.to_s.titleize %></span>
          </div>
          <%= event_date_tag(event.starts_at, classes: "font-mono text-[12px] tracking-[0.14em] uppercase text-accent") %>
          <div class="my-4 text-quote text-[15px] leading-[1.9] flex-grow">
            <%= event_time_tag(event.starts_at) %>
          </div>
          <% if event.location.present? %>
            <span class="text-accent text-[15px] font-bold mt-2"><%= event.location %></span>
          <% end %>
        </article>
      <% end %>
    </div>
  </section>
<% end %>

<%# Section 5 — In photographs (CSS columns masonry) %>
<section class="max-w-[1180px] mx-auto px-6 lg:px-10 py-[80px]">
  <h2 class="font-serif font-medium tracking-[-0.01em] text-ink m-0 mb-10"
      style="font-size: clamp(34px, 4.6vw, 58px);">In photographs</h2>

  <div style="column-count: 4; column-gap: 16px;" class="max-md:!column-count-2 max-sm:!column-count-1">
    <% gradients = %w[#E4E4E4 #EAEAEA #DCDCDC #E8E8E8 #E0E0E0 #ECECEC #DADADA #E6E6E6 #E9E9E9 #DEDEDE #E5E5E5] %>
    <% heights   = [300, 230, 340, 240, 320, 210, 280, 230, 300, 250, 200] %>
    <% (0...11).each do |i| %>
      <% photo = @gallery_photos[i] %>
      <div class="rounded-[3px] mb-4 relative"
           style="break-inside: avoid; height: <%= heights[i] %>px; background: <%= gradients[i] %>;">
        <% if photo&.photo&.attached? %>
          <%= image_tag photo.photo,
                style: "width:100%; height:#{heights[i]}px; object-fit:cover; border-radius:3px;",
                alt: photo.caption.presence || "Memorial photo" %>
        <% end %>
        <span class="absolute left-3.5 bottom-3 font-mono text-[11px] tracking-[0.1em] text-ink/40">[ PHOTO ]</span>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-8">
    <%= link_to "Submit a photo →", new_photo_submission_path,
          class: "no-underline text-accent text-[15px] font-semibold hover:opacity-70 transition-opacity" %>
  </div>
</section>

<%# Section 6 — In their own words (gray band) %>
<section class="bg-band py-[90px]">
  <div class="max-w-[1180px] mx-auto px-6 lg:px-10">
    <h2 class="font-serif font-medium tracking-[-0.01em] text-ink m-0 mb-10"
        style="font-size: clamp(34px, 4.6vw, 58px);">In their own words</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <% @recent_tributes.each do |tribute| %>
        <article class="bg-white-bg rounded-[5px] p-[34px_30px] flex flex-col shadow-[0_1px_2px_rgba(17,17,17,0.05)]">
          <span class="font-serif text-[50px] leading-[0.5] text-accent h-[30px]" aria-hidden="true">&ldquo;</span>
          <p class="font-serif italic text-[19px] leading-[1.5] text-quote mt-3.5 mb-0 flex-grow">
            <%= truncate(tribute.content.to_s, length: 220) %>
          </p>
          <div class="border-t border-ink/10 mt-6 pt-4.5">
            <div class="font-bold text-[15px]"><%= tribute.name %></div>
            <% if tribute.relationship.present? %>
              <div class="font-mono text-[11px] tracking-[0.16em] uppercase text-accent mt-1"><%= tribute.relationship %></div>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
    <div class="text-center mt-9">
      <%= link_to "Read all #{@tributes_count} tributes →", tributes_path,
            class: "no-underline text-accent text-[15px] font-semibold hover:opacity-70 transition-opacity" %>
    </div>
  </div>
</section>

<% content_for(:title, "Christopher Quentin McMullen-Laird — A Life in Music") %>

<!-- Hero -->
<section class="text-center py-16">
  <h1 class="text-5xl md:text-6xl font-title text-stone-800 mb-4">Christopher Quentin</h1>
  <p class="text-xl text-stone-500 font-light mb-2">McMullen-Laird</p>
  <p class="text-lg text-blue-800 mb-8">1984 &mdash; 2020</p>
  <p class="text-stone-600 max-w-2xl mx-auto mb-4 leading-relaxed">
    Conductor. Environmentalist. Beloved.
  </p>
  <p class="text-stone-500 italic max-w-2xl mx-auto mb-8">
    &ldquo;His scintillating charisma and smiling authority inspired singers and musicians alike to surpass themselves!&rdquo;
    <span class="block text-sm mt-1 not-italic">&mdash; Jaerbladet</span>
  </p>
  <%= link_to "Read His Story", chris_path, class: "inline-block px-6 py-3 bg-stone-800 text-blue-100 rounded hover:bg-stone-700 transition font-medium" %>
</section>

<!-- Action Library -->
<section class="py-12" aria-labelledby="action-library-heading">
  <h2 id="action-library-heading" class="text-2xl font-title text-stone-700 text-center mb-2">Honor His Memory</h2>
  <p class="text-stone-500 text-center mb-8">Four ways to keep Christopher&rsquo;s spirit alive.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <%= link_to new_tree_path, class: "group bg-white p-6 rounded-lg shadow-sm border border-stone-200 hover:border-blue-300 hover:shadow-md transition flex flex-col" do %>
      <div class="text-blue-800 mb-4">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3c-3 3-4 5-4 7a4 4 0 008 0c0-2-1-4-4-7z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14v7"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 21h6"/>
        </svg>
      </div>
      <h3 class="text-xl font-title text-blue-900 mb-2">Plant a Tree</h3>
      <p class="text-stone-600 flex-1">Add a tree to the living map of trees planted in his memory.</p>
      <span class="text-blue-800 group-hover:text-blue-700 font-medium mt-4">Plant &rarr;</span>
    <% end %>

    <%= link_to new_memory_path, class: "group bg-white p-6 rounded-lg shadow-sm border border-stone-200 hover:border-blue-300 hover:shadow-md transition flex flex-col" do %>
      <div class="text-blue-800 mb-4">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a2 2 0 012-2h9l5 5v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 3v5h5"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 13h8M8 17h5"/>
        </svg>
      </div>
      <h3 class="text-xl font-title text-blue-900 mb-2">Share a Memory</h3>
      <p class="text-stone-600 flex-1">Photo, story, or note &mdash; contribute to the timeline of his life.</p>
      <span class="text-blue-800 group-hover:text-blue-700 font-medium mt-4">Share &rarr;</span>
    <% end %>

    <%= link_to new_bee_hive_path, class: "group bg-white p-6 rounded-lg shadow-sm border border-stone-200 hover:border-blue-300 hover:shadow-md transition flex flex-col" do %>
      <div class="text-blue-800 mb-4">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 12l8-4.5M12 12l-8-4.5M12 12v9"/>
        </svg>
      </div>
      <h3 class="text-xl font-title text-blue-900 mb-2">Add a Bee Hive</h3>
      <p class="text-stone-600 flex-1">Register a hive on the unified map &mdash; pollinators were one of his loves.</p>
      <span class="text-blue-800 group-hover:text-blue-700 font-medium mt-4">Add &rarr;</span>
    <% end %>

    <%= link_to funds_path, class: "group bg-white p-6 rounded-lg shadow-sm border border-stone-200 hover:border-blue-300 hover:shadow-md transition flex flex-col" do %>
      <div class="text-blue-800 mb-4">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21s-7-4.5-7-10a4 4 0 017-2.6A4 4 0 0119 11c0 5.5-7 10-7 10z"/>
        </svg>
      </div>
      <h3 class="text-xl font-title text-blue-900 mb-2">Support a Fund</h3>
      <p class="text-stone-600 flex-1">Bees, water, music, zero waste, and the Dartmouth Conducting Endowment.</p>
      <span class="text-blue-800 group-hover:text-blue-700 font-medium mt-4">Contribute &rarr;</span>
    <% end %>
  </div>
</section>

<!-- Upcoming Events -->
<% if @upcoming_events.any? %>
  <section class="py-12" aria-labelledby="upcoming-events-heading">
    <h2 id="upcoming-events-heading" class="text-2xl font-title text-stone-700 text-center mb-8">Upcoming Events</h2>
    <div class="space-y-4 max-w-3xl mx-auto">
      <% @upcoming_events.each do |event| %>
        <%= render "events/event_card", event: event %>
      <% end %>
    </div>
    <div class="text-center mt-6">
      <%= link_to "View all events →", events_path, class: "text-blue-800 hover:text-blue-700 font-medium" %>
    </div>
  </section>
<% end %>

<!-- Photo Gallery -->
<section class="py-12">
  <h2 class="text-2xl font-title text-stone-700 text-center mb-8">Gallery</h2>
  <% if @gallery_photos.any? %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% @gallery_photos.each do |photo| %>
        <div class="aspect-square overflow-hidden rounded-lg">
          <%= image_tag photo.photo, class: "w-full h-full object-cover" if photo.photo.attached? %>
        </div>
      <% end %>
    </div>
    <div class="text-center mt-4">
      <%= link_to "Submit Photos", new_photo_submission_path, class: "text-blue-800 hover:text-blue-700 font-medium" %>
    </div>
  <% else %>
    <p class="text-center text-stone-400 italic">Photos coming soon.</p>
  <% end %>
</section>

<!-- Recent Tributes -->
<section class="py-12">
  <h2 class="text-2xl font-title text-stone-700 text-center mb-8">Recent Tributes</h2>
  <% if @recent_tributes.any? %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% @recent_tributes.each do |tribute| %>
        <div class="bg-white p-6 rounded-lg shadow-sm border border-stone-200">
          <p class="text-stone-600 line-clamp-4 mb-4"><%= truncate(tribute.content, length: 200) %></p>
          <p class="text-sm text-blue-800 font-medium">&mdash; <%= tribute.name %></p>
          <% if tribute.relationship.present? %>
            <p class="text-xs text-stone-400"><%= tribute.relationship %></p>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="text-center mt-6">
      <%= link_to "Read All Tributes →", tributes_path, class: "text-blue-800 hover:text-blue-700 font-medium" %>
    </div>
  <% else %>
    <p class="text-center text-stone-400 italic">Tributes will appear here.</p>
  <% end %>
</section>

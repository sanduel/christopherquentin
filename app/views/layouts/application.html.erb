<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Christopher Quentin McMullen-Laird" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || "A memorial celebrating the life and legacy of Christopher Quentin McMullen-Laird, conductor (1984-2020)." %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Christopher Quentin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex flex-col min-h-full bg-stone-50 text-stone-800">
    <!-- Utility bar -->
    <div class="bg-stone-800 text-stone-400 text-xs">
      <div class="max-w-6xl mx-auto px-4 py-1 flex justify-end items-center gap-4">
        <% if user_signed_in? %>
          <span><%= current_user.name %></span>
          <% if current_user.admin? %>
            <%= link_to "Admin", admin_root_path, class: "hover:text-blue-200 transition" %>
          <% end %>
          <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "hover:text-blue-200 transition" %>
        <% else %>
          <%= link_to "Sign in", new_user_session_path, class: "hover:text-blue-200 transition" %>
          <%= link_to "Sign up", new_user_registration_path, class: "hover:text-blue-200 transition" %>
        <% end %>
      </div>
    </div>

    <!-- Header -->
    <header class="bg-stone-900 text-white" data-controller="nav">
      <nav class="max-w-6xl mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <!-- Site name -->
          <a href="<%= root_path %>" class="text-xl font-title tracking-wide text-blue-100 hover:text-blue-50">
            Christopher Quentin
          </a>

          <!-- Desktop nav -->
          <div class="hidden md:flex items-center space-x-6">
            <%= link_to "Chris", chris_path, class: "text-stone-300 hover:text-blue-200 transition" %>
            <%= link_to "Events", events_path, class: "text-stone-300 hover:text-blue-200 transition" %>
            <%= link_to "Map", map_path, class: "text-stone-300 hover:text-blue-200 transition" %>

            <!-- Projects dropdown -->
            <div class="relative group">
              <%= link_to "Projects", projects_path, class: "text-stone-300 hover:text-blue-200 transition" %>
              <div class="absolute hidden group-hover:block top-full left-0 pt-2 z-50">
                <div class="bg-stone-800 rounded-lg shadow-lg py-2 min-w-[160px]">
                  <%= link_to "Trees", trees_path, class: "block px-4 py-2 text-stone-300 hover:text-white hover:bg-stone-700 transition text-sm" %>
                  <%= link_to "Bee Hives", bee_hives_path, class: "block px-4 py-2 text-stone-300 hover:text-white hover:bg-stone-700 transition text-sm" %>
                  <%= link_to "Recipes", recipes_path, class: "block px-4 py-2 text-stone-300 hover:text-white hover:bg-stone-700 transition text-sm" %>
                  <%= link_to "Zero Waste", zero_waste_path, class: "block px-4 py-2 text-stone-300 hover:text-white hover:bg-stone-700 transition text-sm" %>
                  <%= link_to "Funds", funds_path, class: "block px-4 py-2 text-stone-300 hover:text-white hover:bg-stone-700 transition text-sm" %>
                </div>
              </div>
            </div>

            <%= link_to "Updates", updates_path, class: "text-stone-300 hover:text-blue-200 transition" %>
          </div>

          <!-- Mobile hamburger -->
          <button data-action="nav#toggle" class="md:hidden text-stone-300 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>

        <!-- Mobile menu -->
        <div class="hidden md:hidden mt-4 space-y-2" data-nav-target="menu">
          <%= link_to "Chris", chris_path, class: "block text-stone-300 hover:text-blue-200 py-1" %>
          <%= link_to "Events", events_path, class: "block text-stone-300 hover:text-blue-200 py-1" %>
          <%= link_to "Map", map_path, class: "block text-stone-300 hover:text-blue-200 py-1" %>
          <p class="text-stone-500 text-xs uppercase tracking-wide mt-2 mb-1">Projects</p>
          <%= link_to "Trees", trees_path, class: "block text-stone-300 hover:text-blue-200 py-1 ml-4" %>
          <%= link_to "Bee Hives", bee_hives_path, class: "block text-stone-300 hover:text-blue-200 py-1 ml-4" %>
          <%= link_to "Recipes", recipes_path, class: "block text-stone-300 hover:text-blue-200 py-1 ml-4" %>
          <%= link_to "Zero Waste", zero_waste_path, class: "block text-stone-300 hover:text-blue-200 py-1 ml-4" %>
          <%= link_to "Funds", funds_path, class: "block text-stone-300 hover:text-blue-200 py-1 ml-4" %>
          <%= link_to "Updates", updates_path, class: "block text-stone-300 hover:text-blue-200 py-1" %>
        </div>
      </nav>
    </header>

    <!-- Flash messages -->
    <% if notice %>
      <div class="bg-green-50 border-l-4 border-green-400 p-4 max-w-6xl mx-auto mt-4">
        <p class="text-green-700"><%= notice %></p>
      </div>
    <% end %>
    <% if alert %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4 max-w-6xl mx-auto mt-4">
        <p class="text-red-700"><%= alert %></p>
      </div>
    <% end %>

    <!-- Main content -->
    <main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-stone-900 text-stone-400 mt-auto">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Newsletter signup -->
          <div>
            <h3 class="text-blue-100 font-title text-lg mb-3">Stay Updated</h3>
            <%= form_with url: newsletter_subscribers_path, class: "space-y-2" do |f| %>
              <%= f.text_field :name, placeholder: "Your name", class: "w-full px-3 py-2 bg-stone-800 border border-stone-700 rounded text-stone-300 placeholder-stone-500 text-sm" %>
              <%= f.email_field :email, placeholder: "Your email", required: true, class: "w-full px-3 py-2 bg-stone-800 border border-stone-700 rounded text-stone-300 placeholder-stone-500 text-sm" %>
              <%= f.submit "Subscribe", class: "w-full px-3 py-2 bg-blue-800 hover:bg-blue-700 text-white rounded text-sm cursor-pointer transition" %>
            <% end %>
          </div>

          <!-- Quick links -->
          <div>
            <h3 class="text-blue-100 font-title text-lg mb-3">More</h3>
            <ul class="space-y-1 text-sm">
              <li><%= link_to "Submit Photos", new_photo_submission_path, class: "hover:text-blue-200 transition" %></li>
              <li><a href="https://christopherquentin.fillout.com/book" target="_blank" rel="noopener" class="hover:text-blue-200 transition">Order Memorial Book</a></li>
              <li><%= link_to "Share a Tribute", new_tribute_path, class: "hover:text-blue-200 transition" %></li>
            </ul>
          </div>

          <!-- Memorial -->
          <div>
            <h3 class="text-blue-100 font-title text-lg mb-3">Christopher Quentin</h3>
            <p class="text-sm">McMullen-Laird</p>
            <p class="text-sm">1984 &mdash; 2020</p>
            <p class="text-sm mt-2">Conductor. Environmentalist. Beloved.</p>
          </div>
        </div>

        <div class="border-t border-stone-800 mt-8 pt-6 text-center text-xs text-stone-500">
          &copy; <%= Date.current.year %> Christopher Quentin Memorial
        </div>
      </div>
    </footer>
  </body>
</html>

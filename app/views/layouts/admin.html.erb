<!DOCTYPE html>
<html class="h-full">
  <head>
    <title>Admin — Christopher Quentin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex min-h-full bg-stone-100">
    <!-- Sidebar -->
    <aside class="w-64 bg-stone-900 text-stone-300 min-h-screen p-6 hidden md:block">
      <h2 class="text-blue-100 font-title text-lg mb-6">
        <%= link_to "Admin", admin_root_path, class: "hover:text-white" %>
      </h2>
      <nav class="space-y-1">
        <%= link_to "Dashboard", admin_root_path, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition" %>
        <%= link_to "Tributes", admin_tributes_path, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition" %>
        <%= link_to "Memories", admin_memories_path, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition" %>
        <%= link_to "Milestones", admin_milestones_path, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition" %>
        <%= link_to "Trees", admin_trees_path, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition" %>
        <%= link_to "Bee Hives", admin_bee_hives_path, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition" %>
        <%= link_to "Recipes", admin_recipes_path, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition" %>
        <%= link_to "Photos", admin_gallery_photos_path, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition" %>
        <%= link_to "Events", admin_events_path, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition" %>
        <hr class="border-stone-700 my-4">
        <%= link_to "← Back to site", root_path, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition text-sm" %>
        <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-3 py-2 rounded hover:bg-stone-800 hover:text-white transition text-sm" %>
      </nav>
    </aside>

    <!-- Main content -->
    <div class="flex-1 p-8">
      <% if notice %>
        <div class="bg-green-50 border-l-4 border-green-400 p-4 mb-6">
          <p class="text-green-700"><%= notice %></p>
        </div>
      <% end %>
      <% if alert %>
        <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
          <p class="text-red-700"><%= alert %></p>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>

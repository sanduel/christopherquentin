<%# Single recipe card. Local: recipe %>
<article data-recipe-card class="bg-white-bg border border-ink/8 rounded-[5px] overflow-hidden flex flex-col shadow-[0_1px_2px_rgba(17,17,17,0.04)]">
  <% if recipe.photo.attached? %>
    <%= image_tag recipe.photo, class: "w-full aspect-[4/3] object-cover", alt: recipe.title %>
  <% else %>
    <div class="w-full aspect-[4/3] relative"
         style="background: repeating-linear-gradient(135deg, #E6E6E6 0 11px, #EFEFEF 11px 22px);">
      <span class="absolute left-3.5 bottom-3 font-mono text-[11px] tracking-[0.1em] text-ink/40">[ RECIPE ]</span>
    </div>
  <% end %>
  <div class="p-6 flex flex-col flex-grow">
    <span class="font-mono text-[11px] tracking-[0.16em] uppercase text-mono"><%= l(recipe.created_at.to_date, format: :memory) %></span>
    <h3 class="font-serif font-medium text-[22px] text-ink mt-2 leading-tight">
      <%= link_to recipe.title, recipe_path(recipe), class: "no-underline text-ink hover:text-accent" %>
    </h3>
    <p class="font-mono text-[11px] tracking-[0.16em] uppercase text-accent mt-2">from <%= recipe.submitter_name %></p>
    <p class="text-[15px] text-muted leading-[1.55] mt-3 flex-grow"><%= truncate(recipe.ingredients.to_s, length: 100) %></p>
    <%= link_to "Read the full recipe →", recipe_path(recipe),
          class: "text-accent text-[15px] font-semibold mt-5 no-underline hover:opacity-70 transition-opacity" %>
  </div>
</article>

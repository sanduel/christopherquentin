<% content_for :title, "Send a Recipe — Christopher Quentin" %>

<section class="max-w-[760px] mx-auto px-6 lg:px-10 pt-20 pb-24">
  <%# Eyebrow %>
  <div class="flex items-center gap-3">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">Recipes · Submit</span>
  </div>

  <%# Title %>
  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(40px, 5.5vw, 64px); line-height: 1.0;">
    Send a recipe.
  </h1>

  <p class="text-[16px] text-muted mt-5 max-w-[560px]">
    Share a recipe Christopher loved or one that reminds you of him. It will be reviewed before joining the collection.
  </p>

  <%= form_with model: @recipe, class: "space-y-6 mt-12", multipart: true do |f| %>
    <% if @recipe.errors.any? %>
      <div class="bg-band border-l-2 border-[#b91c1c] text-[#b91c1c] px-4 py-3 text-sm">
        <ul class="list-none m-0 p-0 space-y-1">
          <% @recipe.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :submitter_name, "Your name", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
        <%= f.text_field :submitter_name, required: true,
              placeholder: "Full name",
              class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      </div>
      <div>
        <%= f.label :title, "Recipe name", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
        <%= f.text_field :title, required: true,
              placeholder: "e.g. Apple Tart",
              class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      </div>
    </div>

    <div>
      <%= f.label :ingredients, "Ingredients", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.text_area :ingredients, required: true, rows: 6,
            placeholder: "One ingredient per line",
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors leading-relaxed" %>
    </div>

    <div>
      <%= f.label :instructions, "Instructions", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.text_area :instructions, required: true, rows: 8,
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors leading-relaxed" %>
    </div>

    <div>
      <%= f.label :story, "Connection to Christopher (optional)", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.text_area :story, rows: 4,
            placeholder: "Why is this recipe special?",
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors leading-relaxed" %>
    </div>

    <div>
      <%= f.label :photo, "Photo (optional)", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.file_field :photo, accept: "image/*",
            class: "block text-sm text-ink file:mr-4 file:py-2 file:px-4 file:rounded-md file:border file:border-ink/22 file:bg-white-bg file:text-ink file:font-medium hover:file:border-ink" %>
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <%= f.submit "Submit recipe",
            class: "bg-ink text-white-bg no-underline text-[15px] font-semibold py-[15px] px-7 rounded-md hover:bg-ink-deep transition-colors cursor-pointer border-0" %>
      <%= link_to "Cancel", recipes_path,
            class: "self-center text-accent text-[15px] font-semibold no-underline hover:opacity-70 transition-opacity" %>
    </div>
  <% end %>
</section>

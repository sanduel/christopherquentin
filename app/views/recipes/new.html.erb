<% content_for :title, "Submit a Recipe — Christopher Quentin" %>

<section class="px-6 lg:px-14 py-12 lg:py-16 max-w-[760px] mx-auto">
  <%= musical_eyebrow("Op. VIII · Submit a recipe", with_rule: true) %>
  <h1 class="font-serif text-4xl md:text-5xl lg:text-[64px] font-normal leading-tight tracking-tight text-ink mt-3">
    Submit a <em class="font-serif italic text-moss">recipe</em>.
  </h1>
  <p class="text-[17px] text-ink/65 mt-3 max-w-[560px]">
    Share a recipe Christopher loved or one that reminds you of him. It will be reviewed before joining the collection.
  </p>

  <%= form_with model: @recipe, class: "space-y-5 mt-10", multipart: true do |f| %>
    <% if @recipe.errors.any? %>
      <div class="bg-linen border-l-2 border-rose text-rose p-3 text-sm">
        <ul>
          <% @recipe.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :submitter_name, "Your name", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_field :submitter_name, required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :title, "Recipe name", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_field :title, required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :ingredients, "Ingredients", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_area :ingredients, required: true, rows: 6,
            placeholder: "One ingredient per line",
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :instructions, "Instructions", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_area :instructions, required: true, rows: 8,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :story, "Connection to Christopher (optional)", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_area :story, rows: 3,
            placeholder: "Why is this recipe special?",
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :photo, "Photo (optional)", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.file_field :photo, accept: "image/*", class: "block" %>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Submit recipe →",
            class: "bg-moss text-cream rounded-full px-6 py-3 text-sm font-medium hover:bg-ink transition-colors cursor-pointer" %>
      <%= link_to "Cancel", recipes_path,
            class: "text-moss text-sm font-medium hover:underline no-underline self-center" %>
    </div>
  <% end %>
</section>

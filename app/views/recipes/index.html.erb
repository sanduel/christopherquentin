<% content_for(:title, "Recipes — Christopher Quentin") %>

<div class="max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-title text-stone-800">Recipes</h1>
    <%= link_to "Share a Recipe", new_recipe_path, class: "px-4 py-2 bg-blue-800 text-white rounded hover:bg-blue-700 transition" %>
  </div>

  <% if @recipes.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @recipes.each do |recipe| %>
        <%= link_to recipe_path(recipe), class: "block bg-white p-6 rounded-lg shadow-sm border border-stone-200 hover:border-blue-300 transition" do %>
          <% if recipe.photo.attached? %>
            <div class="mb-3">
              <%= image_tag recipe.photo.variant(resize_to_limit: [400, 250]), class: "rounded-lg w-full object-cover" %>
            </div>
          <% end %>
          <h3 class="text-lg font-medium text-stone-800 mb-1"><%= recipe.title %></h3>
          <p class="text-sm text-stone-400 mb-2">by <%= recipe.submitter_name %></p>
          <% if recipe.story.present? %>
            <p class="text-stone-600 text-sm"><%= truncate(recipe.story, length: 150) %></p>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-stone-400 italic text-center py-12">No recipes yet. Share one of Christopher's favorites.</p>
  <% end %>
</div>

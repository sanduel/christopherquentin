<% content_for(:title, "#{@recipe.title} — Christopher Quentin") %>

<div class="max-w-3xl mx-auto">
  <%= link_to "← All Recipes", recipes_path, class: "text-blue-800 hover:text-blue-700 mb-6 inline-block" %>

  <article class="bg-white p-8 rounded-lg shadow-sm border border-stone-200">
    <% if @recipe.photo.attached? %>
      <div class="mb-6">
        <%= image_tag @recipe.photo.variant(resize_to_limit: [600, 400]), class: "rounded-lg w-full object-cover" %>
      </div>
    <% end %>

    <h1 class="text-3xl font-title text-stone-800 mb-2"><%= @recipe.title %></h1>
    <p class="text-stone-400 mb-6">by <%= @recipe.submitter_name %></p>

    <% if @recipe.story.present? %>
      <div class="bg-blue-50 p-4 rounded-lg mb-6">
        <p class="text-stone-600 italic"><%= @recipe.story %></p>
      </div>
    <% end %>

    <h2 class="text-xl font-title text-stone-700 mb-3">Ingredients</h2>
    <div class="text-stone-600 mb-6 whitespace-pre-wrap"><%= @recipe.ingredients %></div>

    <h2 class="text-xl font-title text-stone-700 mb-3">Instructions</h2>
    <div class="text-stone-600 whitespace-pre-wrap"><%= @recipe.instructions %></div>
  </article>
</div>

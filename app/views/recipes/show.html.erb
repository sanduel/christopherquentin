<% content_for :title, "#{@recipe.title} — Christopher Quentin" %>

<section class="max-w-[860px] mx-auto px-6 lg:px-10 pt-20 pb-24">
  <%= link_to "← All recipes", recipes_path,
        class: "font-mono text-[11px] tracking-[0.18em] uppercase text-mono hover:text-accent no-underline transition-colors" %>

  <div class="flex items-center gap-3 mt-8">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">Recipe · <%= l(@recipe.created_at.to_date, format: :memory) %></span>
  </div>

  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(40px, 5vw, 64px); line-height: 1.0;">
    <%= @recipe.title %>
  </h1>

  <p class="font-serif italic text-[20px] text-quote mt-5">from <%= @recipe.submitter_name %></p>

  <% if @recipe.photo.attached? %>
    <%= image_tag @recipe.photo, class: "w-full aspect-[16/9] object-cover rounded-[3px] my-10" %>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mt-10">
    <div>
      <div class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent mb-3">Ingredients</div>
      <div class="font-serif text-[19px] leading-relaxed text-ink whitespace-pre-line"><%= @recipe.ingredients %></div>
    </div>
    <div>
      <div class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent mb-3">Instructions</div>
      <div class="font-serif text-[19px] leading-relaxed text-ink whitespace-pre-line"><%= @recipe.instructions %></div>
    </div>
  </div>
</section>

<% content_for(:title, "Tree planted by #{@tree.name} — Christopher Quentin") %>

<section class="max-w-[860px] mx-auto px-6 lg:px-10 pt-20 pb-24">
  <%= link_to "← All projects", projects_path,
        class: "font-mono text-[11px] tracking-[0.18em] uppercase text-mono hover:text-accent no-underline transition-colors" %>

  <div class="flex items-center gap-3 mt-8">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent"><%= @tree.address %></span>
  </div>

  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(40px, 5vw, 64px); line-height: 1.0;">
    <%= @tree.name %>
  </h1>

  <p class="font-serif italic text-[20px] text-quote mt-5">
    <%= pluralize(@tree.tree_count, "tree") %> planted at <%= @tree.address %>
  </p>

  <% if @tree.photo.attached? %>
    <%= image_tag @tree.photo.variant(resize_to_limit: [960, 600]), class: "w-full aspect-[16/9] object-cover rounded-[3px] border border-ink/8 my-10" %>
  <% end %>

  <% if @tree.story.present? %>
    <div class="mt-10">
      <div class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent mb-4">Story</div>
      <p class="font-serif text-[19px] leading-relaxed text-ink whitespace-pre-line"><%= @tree.story %></p>
    </div>
  <% end %>
</section>

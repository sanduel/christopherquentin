<% content_for(:title, "Tree planted by #{@tree.name} — Christopher Quentin") %>

<section class="px-6 lg:px-14 py-12 lg:py-16 max-w-[960px] mx-auto">
  <%= musical_eyebrow("Tree planted · #{@tree.address}") %>
  <h1 class="font-serif text-4xl md:text-5xl lg:text-[64px] font-normal leading-tight tracking-tight text-ink mt-3">
    <%= @tree.name %>
  </h1>
  <p class="font-serif italic text-xl text-sage mt-4">
    <%= pluralize(@tree.tree_count, "tree") %> planted at <%= @tree.address %>
  </p>

  <% if @tree.photo.attached? %>
    <%= image_tag @tree.photo.variant(resize_to_limit: [960, 600]), class: "w-full aspect-[16/9] object-cover rounded-md border border-ink/8 my-10" %>
  <% end %>

  <% if @tree.story.present? %>
    <div class="mt-10">
      <%= musical_eyebrow("Story") %>
      <p class="font-serif text-[19px] leading-relaxed text-ink mt-4 whitespace-pre-line"><%= @tree.story %></p>
    </div>
  <% end %>

  <div class="mt-12">
    <%= link_to "← All projects", projects_path, class: "text-moss text-sm font-medium hover:underline no-underline" %>
  </div>
</section>

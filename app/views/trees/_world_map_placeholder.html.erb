<%# Stylized world-map placeholder with positioned markers.
    Locals: trees (collection), stats (hash with :trees, :cities, :countries) %>
<section data-section="trees-map" class="relative max-w-[1180px] mx-auto px-6 lg:px-10 py-12">
  <div class="relative h-[400px] md:h-[500px] rounded-[5px] border border-ink/8 overflow-hidden"
       style="background: #F7F8FA;">
    <div class="absolute inset-0 opacity-40"
         style="background-image: radial-gradient(rgba(17,17,17,0.12) 1px, transparent 1px); background-size: 14px 14px;"
         aria-hidden="true"></div>

    <% trees.each do |tree| %>
      <% next unless tree.latitude && tree.longitude %>
      <% x = ((tree.longitude + 180.0) / 360.0 * 100).clamp(0.0, 100.0) %>
      <% y = ((90.0 - tree.latitude) / 180.0 * 100).clamp(0.0, 100.0) %>
      <div data-tree-marker
           class="absolute w-2.5 h-2.5 rounded-full bg-accent -translate-x-1/2 -translate-y-1/2 shadow-[0_0_0_3px_rgba(29,78,216,0.15)]"
           style="left: <%= x %>%; top: <%= y %>%;"
           title="<%= tree.name %>"></div>
    <% end %>

    <div class="absolute top-5 right-5 bg-white-bg rounded-[5px] border border-ink/8 shadow-[0_1px_2px_rgba(17,17,17,0.05)] p-4">
      <div class="font-mono text-[11px] tracking-[0.18em] uppercase text-accent mb-1">Living tally</div>
      <div class="font-serif font-medium text-[24px] text-ink"><%= stats[:trees] %> trees</div>
      <div class="text-[13px] text-muted mt-1"><%= stats[:cities] %> cities · <%= stats[:countries] %> countries</div>
    </div>
  </div>

  <div class="mt-4 text-center">
    <%= link_to "View the full map →", map_path,
          class: "text-accent text-[15px] font-semibold no-underline hover:opacity-70 transition-opacity" %>
  </div>
</section>

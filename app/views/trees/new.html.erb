<% content_for :title, "Plant a Tree — Christopher Quentin" %>

<section class="max-w-[760px] mx-auto px-6 lg:px-10 pt-20 pb-24">
  <%# Eyebrow %>
  <div class="flex items-center gap-3">
    <span class="inline-block w-[34px] h-px bg-accent"></span>
    <span class="font-mono text-[12px] tracking-[0.2em] uppercase text-accent">Plant a tree · Memorial trees</span>
  </div>

  <%# Title %>
  <h1 class="font-serif font-medium tracking-[-0.02em] text-ink mt-6 mb-0"
      style="font-size: clamp(40px, 5.5vw, 64px); line-height: 1.0;">
    Plant a tree.
  </h1>

  <p class="text-[16px] text-muted mt-5 max-w-[560px]">
    Plant a tree in Christopher's memory and add it to our global map. Your submission will be placed immediately.
  </p>

  <%= form_with model: @tree, class: "space-y-6 mt-12", multipart: true do |f| %>
    <% if @tree.errors.any? %>
      <div class="bg-band border-l-2 border-[#b91c1c] text-[#b91c1c] px-4 py-3 text-sm">
        <ul class="list-none m-0 p-0 space-y-1">
          <% @tree.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :name, "Your name", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
        <%= f.text_field :name, required: true,
              placeholder: "Full name",
              class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      </div>
      <div>
        <%= f.label :email, "Email", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
        <%= f.email_field :email, required: true,
              placeholder: "you@example.com",
              class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      </div>
    </div>

    <div>
      <%= f.label :address, "Where did you plant?", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.text_field :address, required: true,
            placeholder: "e.g. 123 Main St, Ann Arbor, MI",
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
      <p class="text-[13px] text-muted mt-1.5">Address, city, and state/country. This will be geocoded to place a pin on the map.</p>
    </div>

    <div>
      <%= f.label :tree_count, "Number of trees", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.number_field :tree_count, value: 1, min: 1,
            class: "w-32 border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors" %>
    </div>

    <div>
      <%= f.label :story, "Tell us about this tree (optional)", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.text_area :story, rows: 5,
            placeholder: "Why did you plant this tree? What does it mean to you?",
            class: "w-full border border-ink/15 rounded-md px-4 py-3 text-[15px] text-ink bg-white-bg focus:border-ink outline-none transition-colors leading-relaxed" %>
    </div>

    <div>
      <%= f.label :photo, "Photo (optional)", class: "font-mono text-[12px] tracking-[0.18em] uppercase text-mono block mb-2" %>
      <%= f.file_field :photo, accept: "image/*",
            class: "block text-sm text-ink file:mr-4 file:py-2 file:px-4 file:rounded-md file:border file:border-ink/22 file:bg-white-bg file:text-ink file:font-medium hover:file:border-ink" %>
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <%= f.submit "Plant my tree",
            class: "bg-ink text-white-bg no-underline text-[15px] font-semibold py-[15px] px-7 rounded-md hover:bg-ink-deep transition-colors cursor-pointer border-0" %>
      <%= link_to "Cancel", projects_path,
            class: "self-center text-accent text-[15px] font-semibold no-underline hover:opacity-70 transition-opacity" %>
    </div>
  <% end %>
</section>

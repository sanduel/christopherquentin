<% content_for :title, "Plant a Tree — Christopher Quentin" %>

<section class="px-6 lg:px-14 py-12 lg:py-16 max-w-[760px] mx-auto">
  <%= musical_eyebrow("Op. VI · The Trees", with_rule: true) %>
  <h1 class="font-serif text-4xl md:text-5xl lg:text-[64px] font-normal leading-tight tracking-tight text-ink mt-3">
    Plant a <em class="font-serif italic text-moss">tree</em>.
  </h1>
  <p class="text-[17px] text-ink/65 mt-3 max-w-[560px]">
    Plant a tree in Christopher's memory and add it to our global map.
  </p>

  <%= form_with model: @tree, class: "space-y-5 mt-10", multipart: true do |f| %>
    <% if @tree.errors.any? %>
      <div class="bg-linen border-l-2 border-rose text-rose p-3 text-sm">
        <ul>
          <% @tree.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Your name", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_field :name, required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :email, "Email", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.email_field :email, required: true,
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :address, "Where did you plant?", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_field :address, required: true,
            placeholder: "e.g. 123 Main St, Ann Arbor, MI",
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
      <p class="text-xs text-ink/40 mt-1">Address, city, and state/country. This will be geocoded to place a pin on the map.</p>
    </div>

    <div>
      <%= f.label :tree_count, "Number of trees", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.number_field :tree_count, value: 1, min: 1,
            class: "w-32 border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :story, "Tell us about this tree (optional)", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.text_area :story, rows: 4,
            placeholder: "Why did you plant this tree? What does it mean to you?",
            class: "w-full border border-ink/15 rounded-md p-3 focus:border-moss outline-none bg-white" %>
    </div>

    <div>
      <%= f.label :photo, "Photo (optional)", class: "text-eyebrow text-sage block mb-1" %>
      <%= f.file_field :photo, accept: "image/*", class: "block" %>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Plant my tree →",
            class: "bg-moss text-cream rounded-full px-6 py-3 text-sm font-medium hover:bg-ink transition-colors cursor-pointer" %>
    </div>
  <% end %>
</section>
